---
import MainLayout from "../layouts/main-layout.astro";
---

<MainLayout title="Privacy Policy | Trackora" description="Privacy policy for Trackora website and services.">
  <main class="bg-[#FAFAFA] text-[#09090B]">
    <section class="w-full pt-24 pb-20 lg:pt-32 lg:pb-24 border-b border-[#E4E4E7]">
      <div class="w-full max-w-[900px] mx-auto px-6 lg:px-12">
        <h1 class="text-[36px] md:text-[52px] font-medium leading-[1.05] tracking-[-0.03em] mb-6">
          Privacy Policy
        </h1>
        <p class="text-[16px] leading-[1.7] text-[#52525B]">
          Effective date: {new Date().toLocaleDateString("en-IN")}
        </p>
      </div>
    </section>

    <section class="w-full py-16 lg:py-20">
      <div class="w-full max-w-[900px] mx-auto px-6 lg:px-12 prose prose-zinc max-w-none">
        <h2>1. Information We Collect</h2>
        <p>
          We collect information you submit through our forms, including name, email address,
          phone number, company details, and message content.
        </p>

        <h2>2. How We Use Information</h2>
        <p>
          We use your information to respond to inquiries, provide demos, support product
          discussions, and improve our services.
        </p>

        <h2>3. Data Sharing</h2>
        <p>
          We do not sell your personal data. We may share data with trusted service providers
          that help us operate our website and communications.
        </p>

        <h2>4. Data Retention</h2>
        <p>
          We retain submitted information only as long as needed for business, legal, or
          operational purposes.
        </p>

        <h2>5. Security</h2>
        <p>
          We apply reasonable technical and organizational safeguards to protect your data.
        </p>

        <h2>6. Your Rights</h2>
        <p>
          You can request access, correction, or deletion of your personal data by contacting us.
        </p>

        <h2>7. Contact</h2>
        <p>
          For privacy requests, email <a href="mailto:support@trackora.tech">support@trackora.tech</a>.
        </p>
      </div>
    </section>
  </main>
</MainLayout>
