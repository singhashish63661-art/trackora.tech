---
import MainLayout from "../layouts/main-layout.astro";
---

<MainLayout
  title="Trackora CMS Panel"
  description="Internal CMS panel to manage website content and incoming enquiries."
>
  <section class="min-h-screen cms-bg cms-dashboard-root w-full py-6 sm:py-8 lg:py-10">
    <div class="cms-shell w-full max-w-[1580px] mx-auto px-4 sm:px-6 lg:px-8">
      <header class="cms-dash-header mb-6 lg:mb-8 rounded-2xl border border-slate-200/90 bg-white/95 backdrop-blur-md px-5 py-4 sm:px-7 sm:py-5 shadow-[0_4px_24px_rgba(15,23,42,0.06)]">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="flex items-start gap-4">
            <div class="cms-brand-mark flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-blue-600 to-indigo-700 text-sm font-bold text-white shadow-md shadow-blue-600/25">
              T
            </div>
            <div class="min-w-0">
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
                Trackora · Internal
              </p>
              <h1 class="text-xl sm:text-2xl font-bold tracking-tight text-slate-900">
                Content dashboard
              </h1>
              <p class="text-sm text-slate-600 mt-1 max-w-xl">
                Manage enquiries, blog, social links, and homepage content from one place.
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                <span class="cms-header-chip">Live content edits</span>
                <span class="cms-header-chip">Blog publishing</span>
                <span class="cms-header-chip">Media + social control</span>
              </div>
            </div>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <a
              href="/"
              target="_blank"
              rel="noopener noreferrer"
              class="cms-btn-secondary inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-800 shadow-sm hover:bg-slate-50"
            >
              View site
            </a>
            <button
              id="crm-logout"
              type="button"
              class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800"
            >
              Log out
            </button>
          </div>
        </div>
      </header>

      <div class="cms-dash-layout lg:grid lg:grid-cols-[260px_minmax(0,1fr)] lg:gap-8 xl:gap-10 lg:items-start">
        <aside class="cms-dash-sidebar mb-6 lg:mb-0 hidden lg:flex lg:flex-col rounded-2xl border border-slate-800/60 bg-gradient-to-b from-slate-900 via-slate-900 to-slate-950 p-4 shadow-xl shadow-slate-900/25 lg:sticky lg:top-6">
          <p class="px-2 text-[10px] font-bold uppercase tracking-[0.2em] text-slate-500">
            Modules
          </p>
          <nav class="mt-3 flex flex-col gap-1" aria-label="CMS sections">
            <a href="#leads-manager" class="cms-side-nav">
              <span class="cms-side-nav-icon" aria-hidden="true">◉</span>
              <span>
                <span class="block font-medium text-slate-100">Leads</span>
                <span class="block text-[11px] text-slate-500">Enquiry pipeline</span>
              </span>
            </a>
            <a href="#blog-manager" class="cms-side-nav">
              <span class="cms-side-nav-icon" aria-hidden="true">✎</span>
              <span>
                <span class="block font-medium text-slate-100">Blog</span>
                <span class="block text-[11px] text-slate-500">Posts &amp; media</span>
              </span>
            </a>
            <a href="#social-manager" class="cms-side-nav">
              <span class="cms-side-nav-icon" aria-hidden="true">◎</span>
              <span>
                <span class="block font-medium text-slate-100">Social</span>
                <span class="block text-[11px] text-slate-500">Footer links</span>
              </span>
            </a>
            <a href="#home-manager" class="cms-side-nav">
              <span class="cms-side-nav-icon" aria-hidden="true">⌂</span>
              <span>
                <span class="block font-medium text-slate-100">Homepage</span>
                <span class="block text-[11px] text-slate-500">Sections &amp; media</span>
              </span>
            </a>
          </nav>
          <p class="mt-auto pt-6 px-2 text-[11px] leading-relaxed text-slate-600">
            Tip: use <strong class="text-slate-400 font-medium">Save</strong> in each module after edits.
          </p>
        </aside>

        <div class="lg:hidden -mx-1 mb-6 overflow-x-auto pb-1">
          <div class="flex min-w-min gap-2 px-1">
            <a href="#leads-manager" class="cms-mnav-chip">Leads</a>
            <a href="#blog-manager" class="cms-mnav-chip">Blog</a>
            <a href="#social-manager" class="cms-mnav-chip">Social</a>
            <a href="#home-manager" class="cms-mnav-chip">Homepage</a>
          </div>
        </div>

        <div class="cms-dash-main min-w-0 space-y-8 lg:space-y-10">
      <div id="leads-manager" class="cms-card cms-module rounded-2xl border border-slate-200/90 bg-white p-5 sm:p-6 lg:p-7 shadow-[0_8px_30px_rgba(15,23,42,0.06)]">
        <div class="cms-module-head mb-6">
          <div class="cms-module-icon bg-blue-50 text-blue-700 ring-blue-100">📥</div>
          <div>
            <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500">Leads</p>
            <h2 class="text-lg sm:text-xl font-bold tracking-tight text-slate-900 mt-0.5">
              Enquiry pipeline
            </h2>
            <p class="text-sm text-slate-600 mt-1">Incoming contact, career, and demo requests.</p>
          </div>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
          <article class="cms-kpi cms-kpi--total">
            <p class="cms-kpi-label">Total</p>
            <p id="stat-total" class="cms-kpi-value">0</p>
          </article>
          <article class="cms-kpi cms-kpi--new">
            <p class="cms-kpi-label">New</p>
            <p id="stat-new" class="cms-kpi-value">0</p>
          </article>
          <article class="cms-kpi cms-kpi--progress">
            <p class="cms-kpi-label">In progress</p>
            <p id="stat-progress" class="cms-kpi-value">0</p>
          </article>
          <article class="cms-kpi cms-kpi--closed">
            <p class="cms-kpi-label">Closed / won</p>
            <p id="stat-closed" class="cms-kpi-value">0</p>
          </article>
        </div>

        <div class="cms-table-shell overflow-x-auto rounded-xl border border-slate-200 bg-white">
          <table class="cms-table min-w-full text-sm">
            <thead>
              <tr>
                <th class="text-left px-4 py-3 font-semibold">Type</th>
                <th class="text-left px-4 py-3 font-semibold">Name</th>
                <th class="text-left px-4 py-3 font-semibold">Email</th>
                <th class="text-left px-4 py-3 font-semibold">Company/Phone</th>
                <th class="text-left px-4 py-3 font-semibold">Message</th>
                <th class="text-left px-4 py-3 font-semibold">Status</th>
              </tr>
            </thead>
            <tbody id="leads-table-body"></tbody>
          </table>
        </div>
      </div>

    <!-- Blog Manager -->
    <div id="blog-manager" class="cms-card cms-module rounded-2xl border border-slate-200/90 bg-white p-5 sm:p-6 lg:p-7 shadow-[0_8px_30px_rgba(15,23,42,0.06)]">
      <div class="cms-module-head mb-6">
        <div class="cms-module-icon bg-violet-50 text-violet-700 ring-violet-100">✎</div>
        <div>
          <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500">Blog</p>
          <h2 class="text-lg sm:text-xl font-bold tracking-tight text-slate-900 mt-0.5">Posts &amp; media</h2>
          <p class="text-sm text-slate-600 mt-1">Add or update posts and cover images.</p>
        </div>
      </div>

      <div class="cms-table-shell overflow-x-auto rounded-xl border border-slate-200 bg-white">
        <table class="cms-table min-w-full text-sm">
          <thead>
            <tr>
              <th class="text-left px-4 py-3 font-semibold">Title</th>
              <th class="text-left px-4 py-3 font-semibold">Category</th>
              <th class="text-left px-4 py-3 font-semibold">Date</th>
              <th class="text-left px-4 py-3 font-semibold">Featured</th>
              <th class="text-left px-4 py-3 font-semibold">Image</th>
              <th class="text-left px-4 py-3 font-semibold">Actions</th>
            </tr>
          </thead>
          <tbody id="blog-table-body"></tbody>
        </table>
      </div>

      <div class="mt-8 rounded-xl border border-slate-200 bg-slate-50/80 p-5 sm:p-6">
        <h3 class="text-base font-bold text-slate-900 mb-5 flex items-center gap-2">
          <span class="h-1.5 w-1.5 rounded-full bg-violet-500"></span>
          Add / update post
        </h3>

        <form
          id="blog-form"
          class="grid grid-cols-1 md:grid-cols-2 gap-4"
          enctype="multipart/form-data"
        >
          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Title</label>
            <input
              name="title"
              required
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder="Post title"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Slug (optional)</label>
            <input
              name="slug"
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder="my-post-slug"
            />
          </div>

          <div class="flex flex-col gap-2 md:col-span-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Excerpt</label>
            <input
              name="excerpt"
              required
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder="Short summary shown in blog cards"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Category</label>
            <input
              name="category"
              required
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder="Research / Case Studies"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Date</label>
            <input
              name="date"
              required
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder='e.g. "AUG 12, 2025"'
            />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Read Time</label>
            <input
              name="readTime"
              required
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder='e.g. "5 MIN"'
            />
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Featured</label>
            <label class="flex items-center gap-2 border border-[#E4E4E7] rounded-lg px-3 py-2 cursor-pointer">
              <input name="featured" type="checkbox" value="true" />
              <span class="text-sm text-[#09090B]">Mark as featured</span>
            </label>
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Cover Image</label>
            <label class="flex items-center gap-2 border border-[#E4E4E7] rounded-lg px-3 py-2 cursor-pointer">
              <input name="removeCoverImage" type="checkbox" value="true" />
              <span class="text-sm text-[#09090B]">Remove cover image</span>
            </label>
          </div>

          <div class="flex flex-col gap-2 md:col-span-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Cover Image (upload)</label>
            <input
              name="coverImage"
              type="file"
              accept="image/*"
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
            />
          </div>

          <div class="flex flex-col gap-2 md:col-span-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Cover Image URL (optional)</label>
            <input
              name="coverImageUrl"
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder="https://example.com/image.jpg"
            />
          </div>

          <div class="flex flex-col gap-2 md:col-span-2">
            <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">Markdown Body</label>
            <textarea
              name="body"
              required
              rows="8"
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder="Write markdown content..."
            ></textarea>
          </div>

          <div class="md:col-span-2 flex items-center justify-end gap-3">
            <button
              type="submit"
              class="px-5 py-3 rounded-lg bg-[#09090B] text-white font-semibold text-sm hover:opacity-90 transition-opacity"
            >
              Save Post
            </button>
          </div>

          <p id="blog-feedback" class="md:col-span-2 text-sm text-[#71717A]"></p>
        </form>
      </div>
    </div>

    <!-- Social Links Manager -->
    <div id="social-manager" class="cms-card cms-module rounded-2xl border border-slate-200/90 bg-white p-5 sm:p-6 lg:p-7 shadow-[0_8px_30px_rgba(15,23,42,0.06)]">
      <div class="cms-module-head mb-6">
        <div class="cms-module-icon bg-sky-50 text-sky-700 ring-sky-100">◎</div>
        <div>
          <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500">Social</p>
          <h2 class="text-lg sm:text-xl font-bold tracking-tight text-slate-900 mt-0.5">Footer social links</h2>
          <p class="text-sm text-slate-600 mt-1">LinkedIn, Instagram, and YouTube URLs.</p>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-slate-50/80 p-5 sm:p-6">
        <form id="social-form" class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <label
              class="text-xs font-bold tracking-wide text-[#71717A] uppercase"
              >LinkedIn URL</label
            >
            <input
              id="social-linkedin"
              name="linkedin"
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder="https://linkedin.com/company/your-page"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label
              class="text-xs font-bold tracking-wide text-[#71717A] uppercase"
              >Instagram URL</label
            >
            <input
              id="social-instagram"
              name="instagram"
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder="https://instagram.com/your-handle"
            />
          </div>

          <div class="flex flex-col gap-2 md:col-span-2">
            <label
              class="text-xs font-bold tracking-wide text-[#71717A] uppercase"
              >YouTube URL</label
            >
            <input
              id="social-youtube"
              name="youtube"
              class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
              placeholder="https://youtube.com/@your-channel"
            />
          </div>

          <div class="md:col-span-2 flex items-center justify-end gap-3 mt-2">
            <button
              type="submit"
              class="px-5 py-3 rounded-lg bg-[#09090B] text-white font-semibold text-sm hover:opacity-90 transition-opacity"
            >
              Save Social Links
            </button>
          </div>

          <p id="social-feedback" class="md:col-span-2 text-sm text-[#71717A]"></p>
        </form>
      </div>
    </div>

    <!-- Home Sections Manager -->
    <div id="home-manager" class="cms-card cms-module rounded-2xl border border-slate-200/90 bg-white p-5 sm:p-6 lg:p-7 shadow-[0_8px_30px_rgba(15,23,42,0.06)]">
      <div class="cms-module-head mb-6">
        <div class="cms-module-icon bg-emerald-50 text-emerald-700 ring-emerald-100">⌂</div>
        <div>
          <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500">Homepage</p>
          <h2 class="text-lg sm:text-xl font-bold tracking-tight text-slate-900 mt-0.5">Site sections &amp; media</h2>
          <p class="text-sm text-slate-600 mt-1">
            Hero, solutions, services, stats, features, benefits, testimonials, and roadmap.
          </p>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-4 sm:p-6">
        <form id="home-sections-form" class="space-y-10">
          <div id="home-hero" class="space-y-6 rounded-2xl border border-[#E4E4E7] bg-[#FCFCFD] p-4">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-[#71717A] mb-2">
                Hero
              </p>
              <h3 class="text-lg font-semibold tracking-tight text-[#09090B]">
                Hero Video, Headlines & CTA
              </h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                  Badge Text
                </label>
                <input
                  id="hero-badge-text"
                  name="hero-badge-text"
                  class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
                />
              </div>

              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                  Video URL
                </label>
                <input
                  id="hero-video-url"
                  name="hero-video-url"
                  class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
                  placeholder="/assets/..."
                />
              </div>

              <div class="flex flex-col gap-2 md:col-span-2">
                <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                  Upload Video (replaces URL)
                </label>
                <input
                  id="hero-video-file"
                  name="hero-video-file"
                  type="file"
                  accept="video/*"
                  class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none bg-white"
                />
                <label class="mt-2 flex items-center gap-2 text-sm text-[#71717A]">
                  <input
                    id="remove-hero-video"
                    type="checkbox"
                    class="rounded border-[#E4E4E7]"
                  />
                  Remove current hero video
                </label>
              </div>

              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                  Title Line 1
                </label>
                <input
                  id="hero-title-line-1"
                  name="hero-title-line-1"
                  class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
                />
              </div>

              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                  Title Line 2
                </label>
                <input
                  id="hero-title-line-2"
                  name="hero-title-line-2"
                  class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
                />
              </div>

              <div class="flex flex-col gap-2 md:col-span-2">
                <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                  Description
                </label>
                <textarea
                  id="hero-description"
                  name="hero-description"
                  rows="3"
                  class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
                ></textarea>
              </div>

              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                  CTA Text
                </label>
                <input
                  id="hero-cta-text"
                  name="hero-cta-text"
                  class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
                />
              </div>

              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                  Demo View Text
                </label>
                <input
                  id="hero-view-demo-text"
                  name="hero-view-demo-text"
                  class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
                />
              </div>

              <div class="flex flex-col gap-2 md:col-span-2">
                <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                  Demo View Href
                </label>
                <input
                  id="hero-view-demo-href"
                  name="hero-view-demo-href"
                  class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none"
                  placeholder="/demo"
                />
              </div>
            </div>

            <div class="space-y-3">
              <p class="text-xs uppercase tracking-[0.2em] text-[#71717A]">
                Press Logos (3)
              </p>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="flex flex-col gap-2">
                  <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                    Logo 1 Text
                  </label>
                  <input id="press-0-text" class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none" />
                </div>
                <div class="flex flex-col gap-2">
                  <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                    Logo 1 Icon
                  </label>
                  <input id="press-0-icon" class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none" placeholder="mdi:..." />
                </div>
                <div class="flex flex-col gap-2">
                  <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                    Logo 1 Font Style
                  </label>
                  <input id="press-0-fontStyle" class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none" placeholder="font-semibold text-sm" />
                </div>

                <div class="flex flex-col gap-2">
                  <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                    Logo 2 Text
                  </label>
                  <input id="press-1-text" class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none" />
                </div>
                <div class="flex flex-col gap-2">
                  <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                    Logo 2 Icon
                  </label>
                  <input id="press-1-icon" class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none" placeholder="mdi:..." />
                </div>
                <div class="flex flex-col gap-2">
                  <label class="text-xs font-bold tracking-wide text-[#71717A] uppercase">
                    Logo 2 Font Style
                  </label>
                  <input id="press-1-fontStyle" class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none" placeholder="font-semibold text-sm" />
                </div>

                <div class="flex flex-col gap-2">
