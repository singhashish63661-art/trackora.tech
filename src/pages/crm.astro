                        <input id={`future-item-${i}-icon`} placeholder="Icon (mdi:...)" class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none" />
                        <input id={`future-item-${i}-offset`} placeholder="Offset class (e.g. lg:translate-y-12)" class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none" />
                        <input id={`future-item-${i}-image-url`} placeholder="Image URL (/assets/...)" class="border border-[#E4E4E7] rounded-lg px-3 py-2 outline-none md:col-span-2" />
                        <label class="flex items-center gap-2 text-sm text-[#71717A] md:col-span-2">
                          <input id={`future-item-${i}-status-live`} type="checkbox" class="rounded border-[#E4E4E7]" />
                          Mark as live status
                        </label>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-end gap-3">
            <button
              type="button"
              id="home-sections-load-defaults"
              class="px-4 py-3 rounded-lg border border-[#E4E4E7] text-sm font-medium text-[#09090B] hover:bg-[#FAFAFA]"
            >
              Reload from Server
            </button>
            <button
              type="submit"
              class="px-5 py-3 rounded-lg bg-[#09090B] text-white font-semibold text-sm hover:opacity-90 transition-opacity"
            >
              Save Home Sections
            </button>
          </div>

          <p id="home-sections-feedback" class="text-sm text-[#71717A]"></p>
        </form>
      </div>
    </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // @ts-nocheck
    async function ensureAuth() {
      const response = await fetch("/api/crm/session", { method: "POST" });
      const payload = await response.json();
      if (!payload.authenticated) {
        window.location.href = "/crm-login";
        return false;
      }
      return true;
    }

    const statusOptions = ["new", "in_progress", "won", "closed"];
    let leads = [];

    function countByStatus(status) {
      return leads.filter((lead) => lead.status === status).length;
    }

    function updateStats() {
      document.getElementById("stat-total").textContent = String(leads.length);
      document.getElementById("stat-new").textContent = String(countByStatus("new"));
      document.getElementById("stat-progress").textContent = String(countByStatus("in_progress"));
      document.getElementById("stat-closed").textContent = String(
        countByStatus("won") + countByStatus("closed")
      );
    }

    async function updateStatus(id, status) {
      const response = await fetch(`/api/crm/lead-status`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id, status }),
      });
      if (response.status === 401) {
        window.location.href = "/crm-login";
        return;
      }
      leads = leads.map((lead) => (lead.id === id ? { ...lead, status } : lead));
      updateStats();
    }

    function renderRows() {
      const tbody = document.getElementById("leads-table-body");
      tbody.innerHTML = "";

      if (!leads.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-[#71717A]">No leads yet.</td></tr>';
        return;
      }

      for (const lead of leads) {
        const tr = document.createElement("tr");
        tr.className = "border-b border-[#F4F4F5] align-top";

        const company = (lead.company || "").trim();
        const phone = (lead.phone || "").trim();
        const companyPhone =
          company && phone
            ? `${company} • ${phone}`
            : company
              ? company
              : phone
                ? phone
                : "-";

        tr.innerHTML = `
          <td class="px-4 py-3 capitalize">${lead.type}</td>
          <td class="px-4 py-3">
            <div class="font-medium">${lead.name || "-"}</div>
            <div class="text-xs text-[#71717A]">${new Date(lead.createdAt).toLocaleString()}</div>
          </td>
          <td class="px-4 py-3">${lead.email || "-"}</td>
          <td class="px-4 py-3">${companyPhone}</td>
          <td class="px-4 py-3 max-w-[280px]">${lead.message || lead.subject || "-"}</td>
          <td class="px-4 py-3">
            <select class="crm-status border border-[#E4E4E7] rounded-lg px-2 py-1 bg-white" data-id="${lead.id}">
              ${statusOptions
                .map(
                  (option) =>
                    `<option value="${option}" ${lead.status === option ? "selected" : ""}>${option.replace("_", " ")}</option>`
                )
                .join("")}
            </select>
          </td>
        `;
        tbody.appendChild(tr);
      }

      const selectors = document.querySelectorAll(".crm-status");
      selectors.forEach((element) => {
        element.addEventListener("change", async (event) => {
          const target = event.target;
          await updateStatus(target.dataset.id, target.value);
        });
      });
    }

    async function loadLeads() {
      const hasAccess = await ensureAuth();
      if (!hasAccess) return;

      const response = await fetch("/api/crm/leads", { method: "POST" });
      if (response.status === 401) {
        window.location.href = "/crm-login";
        return;
      }
      const payload = await response.json();
      leads = payload.leads || [];
      updateStats();
      renderRows();
    }

    const logoutButton = document.getElementById("crm-logout");
    if (logoutButton) {
      logoutButton.addEventListener("click", async () => {
        await fetch("/api/crm/logout", { method: "POST" });
        window.location.href = "/crm-login";
      });
    }

    loadLeads();

    const blogFeedbackEl = document.getElementById("blog-feedback");
    let blogPosts = [];

    function renderBlogRows() {
      const tbody = document.getElementById("blog-table-body");
      tbody.innerHTML = "";

      if (!blogPosts.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-[#71717A]">No blog posts yet.</td></tr>';
        return;
      }

      for (const post of blogPosts) {
        const featuredLabel = post.featured ? "Yes" : "No";
        const imgHtml = post.img
          ? `<img src="${post.img}" alt="${post.title}" class="w-12 h-12 object-cover rounded-lg border border-[#E4E4E7]" />`
          : "-";

        const tr = document.createElement("tr");
        tr.className = "border-b border-[#F4F4F5] align-top";
        tr.innerHTML = `
          <td class="px-4 py-3 font-medium">${post.title || "-"}</td>
          <td class="px-4 py-3">${post.category || "-"}</td>
          <td class="px-4 py-3">${post.date || "-"}</td>
          <td class="px-4 py-3">${featuredLabel}</td>
          <td class="px-4 py-3">${imgHtml}</td>
          <td class="px-4 py-3">
            <div class="flex items-center gap-2">
                <button
                  class="blog-edit px-3 py-2 rounded-lg border border-[#E4E4E7] text-sm font-medium text-[#09090B] hover:bg-[#FAFAFA]"
                  data-slug="${post.slug}"
                >
                  Edit
                </button>
              <button
                class="blog-delete px-3 py-2 rounded-lg border border-[#E4E4E7] text-sm font-medium text-[#09090B] hover:bg-[#FAFAFA]"
                data-slug="${post.slug}"
              >
                Delete
              </button>
            </div>
          </td>
        `;
        tbody.appendChild(tr);
      }

        document.querySelectorAll(".blog-edit").forEach((btn) => {
          btn.addEventListener("click", async () => {
            const slug = btn.dataset.slug;
            if (!slug) return;

            const res = await fetch("/api/crm/blog/get", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ slug }),
            });

            if (res.status === 401) {
              window.location.href = "/crm-login";
              return;
            }

            if (!res.ok) {
              const payload = await res.json().catch(() => ({}));
              blogFeedbackEl.textContent =
                payload.message || "Unable to load post";
              return;
            }

            const payload = await res.json();
            const post = payload.post;
            if (!post) return;

            const titleEl = document.querySelector('#blog-form [name="title"]');
            const slugEl = document.querySelector('#blog-form [name="slug"]');
            const excerptEl = document.querySelector('#blog-form [name="excerpt"]');
            const categoryEl = document.querySelector('#blog-form [name="category"]');
            const dateEl = document.querySelector('#blog-form [name="date"]');
            const readTimeEl = document.querySelector('#blog-form [name="readTime"]');
            const featuredEl = document.querySelector('#blog-form [name="featured"]');
            const coverImageUrlEl = document.querySelector('#blog-form [name="coverImageUrl"]');
            const bodyEl = document.querySelector('#blog-form [name="body"]');
            const removeCoverEl = document.querySelector('#blog-form [name="removeCoverImage"]');
            const coverImageFileEl = document.querySelector('#blog-form [name="coverImage"]');

            if (titleEl) titleEl.value = post.title || "";
            if (slugEl) slugEl.value = post.slug || "";
            if (excerptEl) excerptEl.value = post.excerpt || "";
            if (categoryEl) categoryEl.value = post.category || "";
            if (dateEl) dateEl.value = post.date || "";
            if (readTimeEl) readTimeEl.value = post.readTime || "";
            if (featuredEl) featuredEl.checked = Boolean(post.featured);

            if (coverImageUrlEl) coverImageUrlEl.value = post.img || "";
            if (removeCoverEl) removeCoverEl.checked = false;
            if (coverImageFileEl) coverImageFileEl.value = "";
            if (bodyEl) bodyEl.value = post.body || "";

            blogFeedbackEl.textContent = `Loaded "${post.title || post.slug}" for editing.`;
            // Scroll into view for better UX
            const blogForm = document.getElementById("blog-form");
            if (blogForm) blogForm.scrollIntoView({ behavior: "smooth", block: "start" });
          });
        });

      document.querySelectorAll(".blog-delete").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const slug = btn.dataset.slug;
          if (!slug) return;

          if (!confirm(`Delete blog post "${slug}"?`)) return;

          const res = await fetch("/api/crm/blog/delete", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ slug }),
          });

          if (res.status === 401) {
            window.location.href = "/crm-login";
            return;
          }

          if (!res.ok) {
            const payload = await res.json().catch(() => ({}));
            blogFeedbackEl.textContent = payload.message || "Unable to delete post";
            return;
          }

          blogFeedbackEl.textContent = "Post deleted.";
          await loadBlogPosts();
        });
      });
    }

    async function loadBlogPosts() {
      const hasAccess = await ensureAuth();
      if (!hasAccess) return;

      const res = await fetch("/api/crm/blog/list", { method: "POST" });
      if (res.status === 401) {
        window.location.href = "/crm-login";
        return;
      }

      const payload = await res.json();
      blogPosts = payload.posts || [];
      renderBlogRows();
    }

    const blogForm = document.getElementById("blog-form");
    if (blogForm && blogFeedbackEl) {
      blogForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        blogFeedbackEl.textContent = "Saving...";

        const formData = new FormData(blogForm);
        const featured = blogForm.querySelector('input[name="featured"]')?.checked;
        const removeCover = blogForm.querySelector(
          'input[name="removeCoverImage"]',
        )?.checked;
        // Ensure featured is either "on" or omitted
        if (featured) formData.set("featured", "on");
        else formData.delete("featured");

        if (removeCover) formData.set("removeCoverImage", "on");
        else formData.delete("removeCoverImage");

        const res = await fetch("/api/crm/blog/save", {
          method: "POST",
          body: formData,
        });

        if (res.status === 401) {
          window.location.href = "/crm-login";
          return;
        }

        const payload = await res.json().catch(() => ({}));
        if (!res.ok) {
          blogFeedbackEl.textContent = payload.message || "Unable to save post";
          return;
        }

        blogFeedbackEl.textContent = "Post saved successfully.";
        await loadBlogPosts();
        blogForm.reset();
      });
    }

    loadBlogPosts();

    const socialForm = document.getElementById("social-form");
    const socialFeedbackEl = document.getElementById("social-feedback");

    async function loadSocialLinks() {
      const hasAccess = await ensureAuth();
      if (!hasAccess) return;

      const res = await fetch("/api/crm/settings/get", { method: "POST" });
      if (res.status === 401) {
        window.location.href = "/crm-login";
        return;
      }

      const payload = await res.json().catch(() => ({}));
      const social = payload.settings?.social || {};

      const linkedin = document.getElementById("social-linkedin");
      const instagram = document.getElementById("social-instagram");
      const youtube = document.getElementById("social-youtube");

      if (linkedin) linkedin.value = social.linkedin || "";
      if (instagram) instagram.value = social.instagram || "";
      if (youtube) youtube.value = social.youtube || "";
    }

    if (socialForm && socialFeedbackEl) {
      socialForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        socialFeedbackEl.textContent = "Saving...";

        const linkedin = (document.getElementById("social-linkedin")?.value || "").trim();
        const instagram = (document.getElementById("social-instagram")?.value || "").trim();
        const youtube = (document.getElementById("social-youtube")?.value || "").trim();

        const res = await fetch("/api/crm/settings/save", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            social: { linkedin, instagram, youtube },
          }),
        });

        if (res.status === 401) {
          window.location.href = "/crm-login";
          return;
        }

        const payload = await res.json().catch(() => ({}));
        if (!res.ok) {
          socialFeedbackEl.textContent = payload.message || "Unable to save social links";
          return;
        }

        socialFeedbackEl.textContent = "Social links saved.";
        await loadSocialLinks();
      });
    }

    loadSocialLinks();

    const homeForm = document.getElementById("home-sections-form");
    const homeFeedbackEl = document.getElementById("home-sections-feedback");
    const homeLoadDefaultsBtn = document.getElementById(
      "home-sections-load-defaults",
    );

    let currentHomeSettings = null;

    function getInputValue(id) {
      return (document.getElementById(id)?.value || "").toString();
    }

    function setInputValue(id, value) {
      const el = document.getElementById(id);
      if (!el) return;
      el.value = value ?? "";
    }

    function setCheckboxValue(id, checked) {
      const el = document.getElementById(id);
      if (!el) return;
      el.checked = Boolean(checked);
    }

    function parseMultiline(text) {
      return (text || "")
        .split("\n")
        .map((x) => x.trim())
        .filter(Boolean);
    }

    async function loadHomeSections() {
      const hasAccess = await ensureAuth();
      if (!hasAccess) return;

      const res = await fetch("/api/crm/home/settings/get", { method: "POST" });
      if (res.status === 401) {
        window.location.href = "/crm-login";
        return;
      }

      const payload = await res.json().catch(() => ({}));
      const settings = payload.settings || {};
      currentHomeSettings = settings;

      const hero = settings.hero || {};
      setInputValue("hero-badge-text", hero.badgeText);
      setInputValue("hero-video-url", hero.videoUrl || "");
      setInputValue("hero-title-line-1", hero.titleLine1);
      setInputValue("hero-title-line-2", hero.titleLine2);
      setInputValue("hero-description", hero.description);
      setInputValue("hero-cta-text", hero.ctaText);
      setInputValue("hero-view-demo-text", hero.viewDemoText);
      setInputValue("hero-view-demo-href", hero.viewDemoHref);
      setCheckboxValue("remove-hero-video", false);
      setCheckboxValue("remove-services-video", false);

      const pressLogos = hero.pressLogos || [];
      for (let i = 0; i < 3; i++) {
        const logo = pressLogos[i] || {};
        setInputValue(`press-${i}-text`, logo.text);
        setInputValue(`press-${i}-icon`, logo.icon);
        setInputValue(`press-${i}-fontStyle`, logo.fontStyle);
      }

      const solutions = settings.solutions || {};
      // Back-compat: support both nested `header.*` and older flat keys.
      setInputValue(
        "solutions-badge-text",
        solutions.header?.badgeText || solutions.headerBadgeText,
      );
      setInputValue(
        "solutions-title-line-1",
        solutions.header?.titleLine1 || solutions.headerTitleLine1,
      );
      setInputValue(
        "solutions-title-line-2",
        solutions.header?.titleLine2 || solutions.headerTitleLine2,
      );
      setInputValue(
        "solutions-subtitle",
        solutions.header?.subtitle || solutions.headerSubtitle,
      );

      const live = solutions.live || [];
      for (let i = 0; i < 2; i++) {
        const card = live[i] || {};
        setInputValue(`live-${i}-title`, card.title);
        setInputValue(`live-${i}-icon`, card.icon);
        setInputValue(`live-${i}-description`, card.description);
        setInputValue(`live-${i}-href`, card.href);
        setInputValue(
          `live-${i}-features`,
          (card.features || []).join("\n"),
        );
      }

      const soon = solutions.soon || [];
      for (let i = 0; i < 5; i++) {
        const card = soon[i] || {};
        setInputValue(`soon-${i}-title`, card.title);
        setInputValue(`soon-${i}-icon`, card.icon);
        setInputValue(`soon-${i}-description`, card.description);
      }

      const services = settings.services || {};
      setInputValue("services-video-url", services.dashboardVideoUrl || "");
      setInputValue(
        "services-operational-badge",
        services.operationalBadgeText,
      );
      setInputValue("services-heading-1", services.headingLine1);
      setInputValue("services-heading-2", services.headingLine2);
      setInputValue("services-description", services.description);
      setInputValue("services-explore-text", services.exploreDashboardText);
      setInputValue("services-explore-href", services.exploreDashboardHref);
      setInputValue("services-route-title", services.routeOptimizedTitle);
      setInputValue(
        "services-route-subtitle",
        services.routeOptimizedSubtitle,
      );
      setInputValue("services-route-icon", services.routeOptimizedIcon);
      setInputValue("services-active-title", services.activeFleetTitle);
      setInputValue(
        "services-active-subtitle",
        services.activeFleetSubtitle,
      );
      setInputValue("services-active-icon", services.activeFleetIcon);
      setInputValue("services-app-label", services.appLabel);

      const stats = settings.stats || {};
      setInputValue("stats-badge-text", stats.badgeText || "");
      setInputValue("stats-title", stats.title || "");
      setInputValue("stats-subtitle", stats.subtitle || "");
      const statItems = stats.items || [];
      for (let i = 0; i < 3; i++) {
        const item = statItems[i] || {};
        setInputValue(`stats-item-${i}-label`, item.label || "");
        setInputValue(
          `stats-item-${i}-value`,
          item.value != null && item.value !== "" ? String(item.value) : "",
        );
        setInputValue(`stats-item-${i}-suffix`, item.suffix || "");
        setInputValue(`stats-item-${i}-description`, item.description || "");
      }

      const core = settings.coreFeatures || {};
      setInputValue("core-badge-text", core.badgeText || "");
      setInputValue("core-title", core.title || "");
      setInputValue("core-subtitle", core.subtitle || "");
      const coreItems = core.items || [];
      for (let i = 0; i < 6; i++) {
        const item = coreItems[i] || {};
        setInputValue(`core-item-${i}-id`, item.id || "");
        setInputValue(`core-item-${i}-title`, item.title || "");
        setInputValue(`core-item-${i}-description`, item.description || "");
        setInputValue(`core-item-${i}-icon`, item.icon || "");
        setInputValue(`core-item-${i}-colSpan`, item.colSpan || "");
      }

      const ben = settings.benefits || {};
      setInputValue("benefits-badge-text", ben.badgeText || "");
      setInputValue("benefits-title", ben.title || "");
      setInputValue("benefits-subtitle", ben.subtitle || "");
      setInputValue("benefits-cta-title", ben.ctaTitle || "");
      setInputValue("benefits-cta-subtitle", ben.ctaSubtitle || "");
      setInputValue("benefits-cta-button", ben.ctaButtonText || "");
      const benItems = ben.items || [];
      for (let i = 0; i < 3; i++) {
        const item = benItems[i] || {};
        setInputValue(`benefits-item-${i}-category`, item.category || "");
        setInputValue(`benefits-item-${i}-title`, item.title || "");
        setInputValue(`benefits-item-${i}-description`, item.description || "");
        setInputValue(`benefits-item-${i}-metric`, item.metric || "");
        setInputValue(`benefits-item-${i}-detail`, item.detail || "");
      }

      const testi = settings.testimonials || {};
      setInputValue("testi-badge-text", testi.badgeText || "");
      setInputValue("testi-title", testi.title || "");
      setInputValue("testi-subtitle", testi.subtitle || "");
      const testiItems = testi.items || [];
      for (let i = 0; i < 3; i++) {
        const item = testiItems[i] || {};
        setInputValue(`testi-item-${i}-name`, item.name || "");
        setInputValue(`testi-item-${i}-role`, item.role || "");
        setInputValue(`testi-item-${i}-quote`, item.quote || "");
        setInputValue(
          `testi-item-${i}-rating`,
          item.rating != null ? String(item.rating) : "5",
        );
      }
      const cases = testi.caseStudies || [];
      for (let i = 0; i < 2; i++) {
        const c = cases[i] || {};
        setInputValue(`case-${i}-title`, c.title || "");
        setInputValue(`case-${i}-metric`, c.metric || "");
        setInputValue(`case-${i}-detail`, c.detail || "");
      }

      const future = settings.future || {};
      setInputValue("future-badge-text", future.badgeText || "");
      setInputValue("future-title", future.title || "");
      setInputValue("future-subtitle", future.subtitle || "");
      const futureItems = future.items || [];
      for (let i = 0; i < 3; i++) {
        const item = futureItems[i] || {};
        setInputValue(`future-item-${i}-phase`, item.phase || "");
        setInputValue(`future-item-${i}-status`, item.status || "");
        setInputValue(`future-item-${i}-title`, item.title || "");
        setInputValue(
          `future-item-${i}-description`,
          item.description || "",
        );
        setInputValue(`future-item-${i}-icon`, item.icon || "");
        setInputValue(`future-item-${i}-offset`, item.offset || "");
        setInputValue(`future-item-${i}-image-url`, item.imageUrl || "");
        setCheckboxValue(`future-item-${i}-status-live`, item.statusLive);
      }
    }

    async function deleteIfLocalUrl(url) {
      if (!url || typeof url !== "string") return;
      if (!url.startsWith("/assets/home-media/")) return;
      await fetch("/api/crm/home/media/delete", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ url }),
      }).catch(() => null);
    }

    async function handleSaveHomeSections() {
      if (!currentHomeSettings) return;
      if (homeFeedbackEl) homeFeedbackEl.textContent = "Saving...";

      const heroOld = currentHomeSettings.hero || {};
      const solutionsOld = currentHomeSettings.solutions || {};
      const servicesOld = currentHomeSettings.services || {};

      const heroVideoRemove = document.getElementById("remove-hero-video")
        ?.checked;
      const servicesVideoRemove = document.getElementById("remove-services-video")
        ?.checked;

      if (heroVideoRemove) await deleteIfLocalUrl(heroOld.videoUrl);
      if (servicesVideoRemove)
        await deleteIfLocalUrl(servicesOld.dashboardVideoUrl);

      const hero = {
        ...heroOld,
        badgeText: getInputValue("hero-badge-text"),
        videoUrl: heroVideoRemove ? "" : getInputValue("hero-video-url"),
        titleLine1: getInputValue("hero-title-line-1"),
        titleLine2: getInputValue("hero-title-line-2"),
        description: getInputValue("hero-description"),
        ctaText: getInputValue("hero-cta-text"),
        viewDemoText: getInputValue("hero-view-demo-text"),
        viewDemoHref: getInputValue("hero-view-demo-href"),
        pressLogos: Array.from({ length: 3 }).map((_, i) => ({
          text: getInputValue(`press-${i}-text`),
          icon: getInputValue(`press-${i}-icon`),
          fontStyle: getInputValue(`press-${i}-fontStyle`),
        })),
      };

      const solutions = {
        ...solutionsOld,
        headerBadgeText: getInputValue("solutions-badge-text"),
        headerTitleLine1: getInputValue("solutions-title-line-1"),
        headerTitleLine2: getInputValue("solutions-title-line-2"),
        headerSubtitle: getInputValue("solutions-subtitle"),
        live: Array.from({ length: 2 }).map((_, i) => ({
          title: getInputValue(`live-${i}-title`),
          icon: getInputValue(`live-${i}-icon`),
          description: getInputValue(`live-${i}-description`),
          href: getInputValue(`live-${i}-href`),
          features: parseMultiline(getInputValue(`live-${i}-features`)),
        })),
        soon: Array.from({ length: 5 }).map((_, i) => ({
          title: getInputValue(`soon-${i}-title`),
          icon: getInputValue(`soon-${i}-icon`),
          description: getInputValue(`soon-${i}-description`),
        })),
      };

      const services = {
        ...servicesOld,
        dashboardVideoUrl: servicesVideoRemove
          ? ""
          : getInputValue("services-video-url"),
        operationalBadgeText: getInputValue("services-operational-badge"),
        headingLine1: getInputValue("services-heading-1"),
        headingLine2: getInputValue("services-heading-2"),
        description: getInputValue("services-description"),
        exploreDashboardText: getInputValue("services-explore-text"),
        exploreDashboardHref: getInputValue("services-explore-href"),
        routeOptimizedTitle: getInputValue("services-route-title"),
        routeOptimizedSubtitle: getInputValue("services-route-subtitle"),
        routeOptimizedIcon: getInputValue("services-route-icon"),
        activeFleetTitle: getInputValue("services-active-title"),
        activeFleetSubtitle: getInputValue("services-active-subtitle"),
        activeFleetIcon: getInputValue("services-active-icon"),
        appLabel: getInputValue("services-app-label"),
      };

      const stats = {
        badgeText: getInputValue("stats-badge-text"),
        title: getInputValue("stats-title"),
        subtitle: getInputValue("stats-subtitle"),
        items: Array.from({ length: 3 }).map((_, i) => ({
          label: getInputValue(`stats-item-${i}-label`),
          value: Number.parseFloat(getInputValue(`stats-item-${i}-value`)) || 0,
          suffix: getInputValue(`stats-item-${i}-suffix`),
          description: getInputValue(`stats-item-${i}-description`),
        })),
      };

      const coreFeatures = {
        badgeText: getInputValue("core-badge-text"),
        title: getInputValue("core-title"),
        subtitle: getInputValue("core-subtitle"),
        items: Array.from({ length: 6 }).map((_, i) => ({
          id: getInputValue(`core-item-${i}-id`),
          title: getInputValue(`core-item-${i}-title`),
          description: getInputValue(`core-item-${i}-description`),
          icon: getInputValue(`core-item-${i}-icon`),
          colSpan: getInputValue(`core-item-${i}-colSpan`),
        })),
      };

      const benefits = {
        badgeText: getInputValue("benefits-badge-text"),
        title: getInputValue("benefits-title"),
        subtitle: getInputValue("benefits-subtitle"),
        ctaTitle: getInputValue("benefits-cta-title"),
        ctaSubtitle: getInputValue("benefits-cta-subtitle"),
        ctaButtonText: getInputValue("benefits-cta-button"),
        items: Array.from({ length: 3 }).map((_, i) => ({
          category: getInputValue(`benefits-item-${i}-category`),
          title: getInputValue(`benefits-item-${i}-title`),
          description: getInputValue(`benefits-item-${i}-description`),
          metric: getInputValue(`benefits-item-${i}-metric`),
          detail: getInputValue(`benefits-item-${i}-detail`),
        })),
      };

      const ratingRaw = (id) =>
        Math.min(
          5,
          Math.max(
            1,
            Math.round(Number.parseFloat(getInputValue(id)) || 5),
          ),
        );

      const testimonials = {
        badgeText: getInputValue("testi-badge-text"),
        title: getInputValue("testi-title"),
        subtitle: getInputValue("testi-subtitle"),
        items: Array.from({ length: 3 }).map((_, i) => ({
          name: getInputValue(`testi-item-${i}-name`),
          role: getInputValue(`testi-item-${i}-role`),
          quote: getInputValue(`testi-item-${i}-quote`),
          rating: ratingRaw(`testi-item-${i}-rating`),
        })),
        caseStudies: Array.from({ length: 2 }).map((_, i) => ({
          title: getInputValue(`case-${i}-title`),
          metric: getInputValue(`case-${i}-metric`),
          detail: getInputValue(`case-${i}-detail`),
        })),
      };

      const future = {
        badgeText: getInputValue("future-badge-text"),
        title: getInputValue("future-title"),
        subtitle: getInputValue("future-subtitle"),
        items: Array.from({ length: 3 }).map((_, i) => ({
          phase: getInputValue(`future-item-${i}-phase`),
          status: getInputValue(`future-item-${i}-status`),
          statusLive: Boolean(
            document.getElementById(`future-item-${i}-status-live`)?.checked,
          ),
          title: getInputValue(`future-item-${i}-title`),
          description: getInputValue(`future-item-${i}-description`),
          icon: getInputValue(`future-item-${i}-icon`),
          imageUrl: getInputValue(`future-item-${i}-image-url`),
          offset: getInputValue(`future-item-${i}-offset`),
        })),
      };

      const res = await fetch("/api/crm/home/settings/save", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          hero,
          solutions,
          services,
          stats,
          coreFeatures,
          benefits,
          testimonials,
          future,
        }),
      });

      if (res.status === 401) {
        window.location.href = "/crm-login";
        return;
      }

      const payload = await res.json().catch(() => ({}));
      if (!res.ok) {
        if (homeFeedbackEl)
          homeFeedbackEl.textContent =
            payload.message || "Unable to save home sections";
        return;
      }

      if (homeFeedbackEl) homeFeedbackEl.textContent = "Home sections saved.";
      await loadHomeSections();
    }

    if (homeForm) {
      homeForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        await handleSaveHomeSections();
      });
    }

    if (homeLoadDefaultsBtn) {
      homeLoadDefaultsBtn.addEventListener("click", async () => {
        await loadHomeSections();
        if (homeFeedbackEl) homeFeedbackEl.textContent = "Reloaded from server.";
      });
    }

    const heroVideoFile = document.getElementById("hero-video-file");
    const heroVideoUrlEl = document.getElementById("hero-video-url");
    const removeHeroVideoEl = document.getElementById("remove-hero-video");

    if (heroVideoFile && heroVideoUrlEl) {
      heroVideoFile.addEventListener("change", async () => {
        const file = heroVideoFile.files?.[0];
        if (!file) return;

        if (homeFeedbackEl) homeFeedbackEl.textContent = "Uploading hero video...";
        const formData = new FormData();
        formData.append("file", file);
        formData.append("kind", "heroVideo");

        const res = await fetch("/api/crm/home/media/upload", {
          method: "POST",
          body: formData,
        });
        const payload = await res.json().catch(() => ({}));
        if (!res.ok) {
          if (homeFeedbackEl)
            homeFeedbackEl.textContent =
              payload.message || "Hero video upload failed";
          return;
        }

        if (payload.url) {
          heroVideoUrlEl.value = payload.url;
          if (removeHeroVideoEl) removeHeroVideoEl.checked = false;
        }
        if (homeFeedbackEl) homeFeedbackEl.textContent = "Hero video uploaded.";
      });
    }

    const servicesVideoFile = document.getElementById("services-video-file");
    const servicesVideoUrlEl = document.getElementById("services-video-url");
    const removeServicesVideoEl = document.getElementById("remove-services-video");

    if (servicesVideoFile && servicesVideoUrlEl) {
      servicesVideoFile.addEventListener("change", async () => {
        const file = servicesVideoFile.files?.[0];
        if (!file) return;

        if (homeFeedbackEl)
          homeFeedbackEl.textContent = "Uploading dashboard video...";
        const formData = new FormData();
        formData.append("file", file);
        formData.append("kind", "dashboardVideo");

        const res = await fetch("/api/crm/home/media/upload", {
          method: "POST",
          body: formData,
        });
        const payload = await res.json().catch(() => ({}));
        if (!res.ok) {
          if (homeFeedbackEl)
            homeFeedbackEl.textContent =
              payload.message || "Dashboard video upload failed";
          return;
        }

        if (payload.url) {
          servicesVideoUrlEl.value = payload.url;
          if (removeServicesVideoEl) removeServicesVideoEl.checked = false;
        }
        if (homeFeedbackEl) homeFeedbackEl.textContent = "Dashboard video uploaded.";
      });
    }

    loadHomeSections();
  </script>
</MainLayout>

