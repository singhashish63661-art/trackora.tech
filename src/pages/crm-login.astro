---
import MainLayout from "../layouts/main-layout.astro";
---

<MainLayout
  title="CMS Login | Trackora"
  description="Authenticate to access Trackora CMS panel."
  robots="noindex, nofollow"
>
  <section class="w-full max-w-[520px] mx-auto px-6 py-20">
    <div class="rounded-2xl border border-[#E4E4E7] bg-white p-8 md:p-10">
      <p class="text-xs uppercase tracking-[0.2em] text-[#71717A] mb-3">Internal</p>
      <h1 class="text-3xl font-semibold tracking-tight text-[#09090B]">CMS Login</h1>
      <p class="text-sm text-[#71717A] mt-3 mb-8">
        Enter your admin password to access the CMS panel.
      </p>

      <form id="crm-login-form" class="space-y-4">
        <div>
          <label for="crm-password" class="block text-xs font-medium text-[#52525B] mb-2 uppercase tracking-wide">
            Admin Password
          </label>
          <input
            id="crm-password"
            name="password"
            type="password"
            required
            class="w-full px-4 py-3 rounded-lg border border-[#E4E4E7] bg-[#FAFAFA] focus:bg-white focus:border-[#09090B] outline-none"
            placeholder="Enter password"
          />
        </div>
        <button
          id="crm-login-submit"
          type="submit"
          class="w-full py-3 rounded-lg bg-[#09090B] text-white font-semibold text-sm hover:opacity-90 transition-opacity"
        >
          Login
        </button>
        <p id="crm-login-feedback" class="text-sm text-[#71717A]"></p>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById("crm-login-form");
    const button = document.getElementById("crm-login-submit");
    const feedback = document.getElementById("crm-login-feedback");

    if (form instanceof HTMLFormElement && button instanceof HTMLButtonElement && feedback instanceof HTMLElement) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        button.setAttribute("disabled", "true");
        feedback.textContent = "Authenticating...";

        const formData = new FormData(form);
        const password = String(formData.get("password") || "");

        try {
          const response = await fetch("/api/crm/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ password }),
          });

          if (!response.ok) {
            const payload = await response.json().catch(() => ({ message: "Login failed" }));
            throw new Error(payload.message || "Login failed");
          }

          feedback.textContent = "Login successful. Redirecting...";
          window.location.href = "/crm";
        } catch (error) {
          feedback.textContent = error instanceof Error ? error.message : "Login failed";
        } finally {
          button.removeAttribute("disabled");
        }
      });
    }
  </script>
</MainLayout>
