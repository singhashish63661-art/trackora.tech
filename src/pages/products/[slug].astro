---
import { Icon } from "astro-icon/components";
import MainLayout from "../../layouts/main-layout.astro";
import { getCollection } from "astro:content";
import { getCanonicalUrl, toAbsoluteUrl } from "../../lib/seo-utils";

const slug = Astro.params.slug;
const products = await getCollection("products");
const product = products.find((entry) => entry.slug === slug);
const rendered = product ? await product.render() : null;
const Content = rendered?.Content;

const canonicalUrl = product
    ? getCanonicalUrl(Astro.site, `/products/${product.slug}`)
    : getCanonicalUrl(Astro.site, `/products/${slug ?? ""}`);
const ogImage = product?.data?.img
    ? toAbsoluteUrl(Astro.site, product.data.img)
    : toAbsoluteUrl(Astro.site, "/assets/logo.png");
---

<MainLayout
    title={product ? `${product.data.title} | Trackora` : "Product Not Found | Trackora"}
    description={product?.data?.excerpt || "Requested product could not be found."}
    canonicalUrl={canonicalUrl}
    ogImage={ogImage}
    ogImageAlt={product ? product.data.title : "Trackora"}
    robots={product ? undefined : "noindex, follow"}
>
    <main
        class="bg-[#FAFAFA] dark:bg-[#09090B] font-sans text-[#09090B] dark:text-white"
    >
        {!product && (
                <section class="w-full max-w-[960px] mx-auto px-4 sm:px-6 lg:px-12 py-20 sm:py-32">
                    <p class="text-xs uppercase tracking-[0.2em] text-[#71717A] mb-4">Products</p>
                    <h1 class="text-[28px] sm:text-[36px] md:text-[48px] font-semibold tracking-tight mb-4 text-[#09090B] dark:text-white">
                        Product not found
                    </h1>
                    <p class="text-[16px] sm:text-[17px] leading-[1.7] text-[#71717A] dark:text-[#A1A1AA] mb-8">
                        The requested product page is unavailable or may have moved.
                    </p>
                    <a
                        href="/products"
                        class="inline-flex items-center justify-center min-h-[48px] gap-2 px-5 py-3 rounded-full bg-[#09090B] text-white text-sm font-semibold hover:opacity-90 w-full sm:w-auto"
                    >
                        Back to Products <Icon name="mdi:arrow-right" class="w-4 h-4" />
                    </a>
                </section>
        )}
        {product && Content && (
                <>
        <!-- HERO -->
        <section
            class="relative w-full pt-32 pb-16 lg:pt-48 lg:pb-24 border-b border-[#E4E4E7] dark:border-white/10 overflow-hidden"
        >
            <div
                class="absolute inset-0 z-0 opacity-20 pointer-events-none hidden md:block"
            >
                <div
                    class="absolute inset-0 bg-[linear-gradient(to_right,#000000_1px,transparent_1px),linear-gradient(to_bottom,#000000_1px,transparent_1px)] bg-[size:6rem_6rem] [mask-image:radial-gradient(ellipse_80%_80%_at_50%_50%,#000_20%,transparent_100%)] opacity-[0.05]"
                >
                </div>
            </div>

            <div
                class="relative w-full max-w-[1440px] mx-auto px-6 lg:px-12 z-10"
            >
                <a
                    href="/products"
                    class="inline-flex items-center gap-2 text-[11px] font-bold tracking-[0.2em] uppercase text-[#A1A1AA] dark:text-[#71717A] hover:text-[#09090B] dark:text-white transition-colors mb-12"
                >
                    <Icon name="mdi:arrow-left" class="w-4 h-4" /> All Products
                </a>

                <div
                    class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 xl:gap-16 items-start lg:items-end"
                >
                    <div class="min-w-0 lg:col-span-8">
                        <div class="flex flex-wrap items-center gap-3 mb-8">
                            {
                                product.data.category && (
                                    <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-[#A1A1AA] dark:text-[#71717A] border border-[#E4E4E7] dark:border-white/10 bg-white dark:bg-[#121214] px-2.5 py-1 rounded-md">
                                        {product.data.category}
                                    </span>
                                )
                            }
                            {
                                product.data.live ? (
                                    <span class="flex items-center gap-1.5 text-[10px] font-bold tracking-[0.15em] uppercase text-blue-600 bg-blue-50 border border-blue-200 px-2.5 py-1 rounded-md">
                                        <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse inline-block" />
                                        Available Now
                                    </span>
                                ) : (
                                    <span class="text-[10px] font-bold tracking-[0.15em] uppercase text-[#A1A1AA] dark:text-[#71717A] bg-[#F4F4F5] dark:bg-white/5 border border-[#E4E4E7] dark:border-white/10 px-2.5 py-1 rounded-md">
                                        Coming Soon
                                    </span>
                                )
                            }
                        </div>

                        <h1
                            class="text-[28px] sm:text-[36px] md:text-[52px] lg:text-[64px] font-medium leading-[1.08] sm:leading-[1.05] tracking-[-0.04em] text-[#09090B] dark:text-white break-words"
                        >
                            {product.data.title}
                        </h1>
                    </div>

                    <div
                        class="min-w-0 lg:col-span-4 flex flex-col justify-end lg:pb-3"
                    >
                        <p
                            class="text-[16px] md:text-[19px] leading-[1.65] text-[#71717A] dark:text-[#A1A1AA] font-normal break-words"
                        >
                            {product.data.excerpt}
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Mobile: key actions (desktop sidebar is lg+) -->
        <div class="lg:hidden w-full max-w-[1440px] mx-auto px-4 sm:px-6 pb-8">
            <div class="rounded-2xl border border-[#E4E4E7] dark:border-white/10 bg-white dark:bg-[#121214] p-4 sm:p-5 space-y-4">
                <div class="flex flex-wrap gap-2">
                    {product.data.category && (
                        <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-[#71717A] border border-[#E4E4E7] dark:border-white/10 px-2.5 py-1 rounded-md">
                            {product.data.category}
                        </span>
                    )}
                    <span class={`text-[10px] font-bold tracking-[0.15em] uppercase px-2.5 py-1 rounded-md ${product.data.live ? "text-blue-600 bg-blue-50 border border-blue-200" : "text-[#71717A] bg-[#F4F4F5] dark:bg-white/5 border border-[#E4E4E7] dark:border-white/10"}`}>
                        {product.data.live ? "Available now" : "Coming soon"}
                    </span>
                </div>
                <a
                    href="/contact"
                    class="flex items-center justify-center min-h-[48px] w-full gap-2 px-5 py-3 bg-[#09090B] dark:bg-[#FAFAFA] text-white dark:text-[#09090B] text-[13px] font-bold rounded-full hover:opacity-90"
                >
                    Request demo <Icon name="mdi:arrow-right" class="w-4 h-4" />
                </a>
                <a
                    href="/products"
                    class="flex items-center justify-center gap-2 text-[12px] font-bold text-[#71717A] hover:text-[#09090B] dark:hover:text-white uppercase tracking-wide"
                >
                    <Icon name="mdi:arrow-left" class="w-4 h-4" /> All products
                </a>
            </div>
        </div>

        <!-- COVER IMAGE -->
        {
            product.data.img && (
                <div class="w-full max-w-[1440px] mx-auto px-6 lg:px-12 pt-12">
                    <div class="relative w-full aspect-[16/7] rounded-[2rem] overflow-hidden border border-[#E4E4E7] dark:border-white/10 bg-[#F8FAFC] dark:bg-[#18181A] shadow-sm">
                        <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(#000_1px,transparent_1px)] bg-[size:15px_15px]" />
                        <img
                            loading="lazy"
                            decoding="async"
                            src={product.data.img}
                            alt={product.data.title}
                            class={`relative z-10 w-full h-full ${
                                product.slug === "fleet-management"
                                    || product.slug === "realtime-visibility"
                                    ? "object-contain p-3 bg-white"
                                    : "object-cover"
                            }`}
                        />
                    </div>
                </div>
            )
        }

        <!-- CONTENT -->
        <div class="w-full max-w-[1440px] mx-auto px-6 lg:px-12 py-16 lg:py-24">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                <!-- sidebar -->
                <aside
                    class="lg:col-span-3 hidden lg:flex flex-col gap-8 sticky top-28 self-start"
                >
                    <div
                        class="w-12 h-12 rounded-xl bg-gradient-to-br from-slate-700 via-slate-800 to-[#09090B] flex items-center justify-center shadow-md border border-white dark:border-white/10"
                    >
                        <Icon
                            name={product.data.icon}
                            class="w-6 h-6 text-white dark:text-[#09090B]/90"
                        />
                    </div>

                    {
                        product.data.category && (
                            <div>
                                <span class="text-[9px] font-bold tracking-[0.25em] uppercase text-[#A1A1AA] dark:text-[#71717A] block mb-2">
                                    Category
                                </span>
                                <span class="text-[13px] font-bold tracking-wide text-[#09090B] dark:text-white border border-[#E4E4E7] dark:border-white/10 px-3 py-1.5 rounded-md inline-block">
                                    {product.data.category}
                                </span>
                            </div>
                        )
                    }

                    <div>
                        <span
                            class="text-[9px] font-bold tracking-[0.25em] uppercase text-[#A1A1AA] dark:text-[#71717A] block mb-2"
                            >Availability</span
                        >
                        <span
                            class={`text-[13px] font-bold ${product.data.live ? "text-blue-600" : "text-[#A1A1AA] dark:text-[#71717A]"}`}
                        >
                            {
                                product.data.live
                                    ? "Available Now"
                                    : "Coming Soon"
                            }
                        </span>
                    </div>

                    <div
                        class="pt-6 border-t border-[#E4E4E7] dark:border-white/10 flex flex-col gap-3"
                    >
                        <a
                            href="/contact"
                            class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-[#09090B] dark:bg-[#121214] text-white dark:text-[#09090B] text-[12px] font-bold rounded-full hover:bg-slate-800 transition-colors"
                        >
                            Request Demo <Icon
                                name="mdi:arrow-right"
                                class="w-3.5 h-3.5"
                            />
                        </a>
                        <a
                            href="/products"
                            class="text-[12px] font-bold tracking-wide text-[#A1A1AA] dark:text-[#71717A] hover:text-[#09090B] dark:text-white transition-colors flex items-center gap-2 uppercase"
                        >
                            <Icon name="mdi:arrow-left" class="w-4 h-4" /> All Products
                        </a>
                    </div>
                </aside>

                <!-- article body -->
                <article
                    class="lg:col-span-9 prose prose-zinc prose-headings:font-semibold prose-headings:tracking-tight prose-h2:text-[28px] prose-h3:text-[20px] prose-p:text-[17px] prose-p:leading-[1.8] prose-p:text-[#52525B] dark:text-[#C4C4CE] prose-li:text-[#52525B] dark:text-[#C4C4CE] prose-li:text-[16px] prose-strong:text-[#09090B] dark:text-white prose-table:text-[14px] max-w-none"
                >
                    <Content />
                </article>
            </div>
        </div>

        <!-- FOOTER STRIP -->
        <div class="border-t border-[#E4E4E7] dark:border-white/10">
            <div
                class="w-full max-w-[1440px] mx-auto px-6 lg:px-12 py-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8"
            >
                <div>
                    <p
                        class="text-[10px] font-bold tracking-[0.2em] uppercase text-[#A1A1AA] dark:text-[#71717A] mb-3"
                    >
                        Explore More
                    </p>
                    <a
                        href="/products"
                        class="text-[20px] font-bold tracking-tight text-[#09090B] dark:text-white hover:text-[#71717A] dark:text-[#A1A1AA] transition-colors flex items-center gap-3"
                    >
                        All Products <Icon
                            name="mdi:arrow-right"
                            class="w-5 h-5"
                        />
                    </a>
                </div>
                <a
                    href="/contact"
                    class="inline-flex items-center gap-2 text-[13px] font-bold tracking-wide text-[#09090B] dark:text-white border-b-2 border-[#09090B] dark:border-white/10 pb-0.5 hover:opacity-60 transition-opacity"
                >
                    Request a Demo <Icon
                        name="mdi:arrow-right"
                        class="w-4 h-4"
                    />
                </a>
            </div>
        </div>
                </>
        )}
    </main>
</MainLayout>
