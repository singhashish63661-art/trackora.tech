---
const steps = [
    {
        id: "step-1",
        number: "01",
        title: "Seamless Integration",
        description:
            "Deploy our lightweight telemetry agents across your fleet. Within minutes, Trackora begins ingesting millions of data points across routing, vehicle health, and environmental factors.",
        iconUrl: "/assets/images/seamless-integration-step.png",
    },
    {
        id: "step-2",
        number: "02",
        title: "Real-time Analysis",
        description:
            "Data flows into our sub-millisecond processing engine. Proprietary algorithms instantly clean, structure, and analyze the telemetry against historical predictive models.",
        iconUrl: "/assets/images/real-time-analysis-step.png",
    },
    {
        id: "step-3",
        number: "03",
        title: "Automated Execution",
        description:
            "Trackora doesn't just report; it acts. The system autonomously reroutes drivers, anticipates maintenance failures, and neutralizes supply chain bottlenecks before they happen.",
        iconUrl: "/assets/images/automated-execution-step.png",
    },
];
---

<section
    id="how-it-works"
    class="relative w-full py-20 lg:py-32 bg-[#FAFAFA] font-sans text-[#09090B] border-t border-[#E4E4E7]"
>
    <div
        class="absolute inset-0 z-0 overflow-hidden pointer-events-none hidden md:block"
    >
        <div
            class="absolute inset-0 bg-[linear-gradient(to_right,#000000_1px,transparent_1px),linear-gradient(to_bottom,#000000_1px,transparent_1px)] bg-[size:6rem_6rem] [mask-image:radial-gradient(ellipse_80%_100%_at_50%_0%,#000_20%,transparent_100%)] opacity-[0.05]"
        >
        </div>
    </div>

    <div class="relative w-full max-w-[1440px] mx-auto px-6 lg:px-12 z-10">
        <div
            class="flex flex-col items-center text-center mb-16 lg:mb-32 animate-fade-in-up"
        >
            <div
                class="flex items-center gap-2 px-3 py-1.5 border border-[#E4E4E7] bg-white rounded-full mb-6 shadow-[0_2px_10px_rgba(0,0,0,0.02)]"
            >
                <span class="relative flex h-1.5 w-1.5 ml-1">
                    <span
                        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"
                    ></span>
                    <span
                        class="relative inline-flex rounded-full h-1.5 w-1.5 bg-blue-500"
                    ></span>
                </span>
                <span
                    class="text-[10px] font-bold tracking-[0.1em] uppercase text-[#52525B]"
                    >Get Started in 3 Steps</span
                >
            </div>
            <h2
                class="text-[40px] md:text-[56px] font-medium leading-[1.05] tracking-[-0.03em] text-[#09090B] max-w-[800px]"
            >
                How Trackora works.
            </h2>
        </div>

        <div
            class="flex flex-col lg:grid lg:grid-cols-12 gap-12 lg:gap-24 items-start relative"
        >
            <div
                class="hidden lg:flex lg:col-span-6 sticky top-[15vh] h-[70vh] max-h-[700px] w-full items-center justify-center"
            >
                <div
                    class="relative w-full h-full bg-gradient-to-b from-[#F8FAFC] to-[#F1F5F9] rounded-[2.5rem] border border-[#E2E8F0]/80 shadow-[0_30px_80px_rgba(0,0,0,0.05)] overflow-hidden flex items-center justify-center group"
                >
                    <div
                        class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(56,189,248,0.12)_0%,transparent_60%)] z-0"
                    >
                    </div>

                    <div
                        class="absolute inset-x-0 top-0 h-[200px] bg-gradient-to-b from-transparent via-sky-400/10 to-transparent -translate-y-full animate-scan-beam z-20 pointer-events-none"
                    >
                    </div>
                    <div
                        class="absolute inset-x-0 top-0 h-[1px] bg-sky-400/30 -translate-y-full animate-scan-line z-20 pointer-events-none shadow-[0_0_15px_rgba(56,189,248,0.5)]"
                    >
                    </div>

                    {
                        steps.map((step, index) => (
                            <div
                                id={`visual-${index}`}
                                class={`absolute z-10 w-full h-full flex items-center justify-center transition-all duration-[1200ms] ease-[cubic-bezier(0.16,1,0.3,1)] ${index === 0 ? "opacity-100 scale-100 translate-y-0" : "opacity-0 scale-90 translate-y-12"}`}
                            >
                                <img
                                    loading="lazy" decoding="async" src={step.iconUrl}
                                    alt={step.title}
                                    class="w-[85%] max-w-[520px] h-auto object-contain mix-blend-multiply"
                                />
                            </div>
                        ))
                    }
                </div>
            </div>

            <div
                class="lg:col-span-6 flex flex-col relative w-full pt-10 pb-[20vh] lg:pb-[30vh]"
            >
                <div
                    class="absolute left-[27px] top-14 bottom-[30vh] w-[2px] bg-[#E4E4E7] hidden sm:block rounded-full z-0"
                >
                    <div
                        id="scroll-progress-line"
                        class="absolute top-0 left-0 w-full bg-gradient-to-b from-[#09090B] to-[#09090B] transition-all duration-500 ease-out origin-top rounded-full shadow-[0_0_10px_rgba(0,0,0,0.2)]"
                        style="height: 0%;"
                    >
                    </div>
                </div>

                {
                    steps.map((step, index) => (
                        <div
                            class="scroll-step relative flex flex-col sm:flex-row gap-8 sm:gap-12 min-h-[40vh] lg:min-h-[70vh] transition-all duration-[800ms] ease-[cubic-bezier(0.16,1,0.3,1)] opacity-20 translate-y-8"
                            data-index={index}
                        >
                            <div class="lg:hidden w-full h-[280px] bg-gradient-to-b from-[#F8FAFC] to-[#F1F5F9] rounded-2xl mb-6 flex items-center justify-center border border-[#E2E8F0]/80 relative overflow-hidden">
                                <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(56,189,248,0.1)_0%,transparent_70%)] z-0" />
                                <img
                                    loading="lazy" decoding="async" src={step.iconUrl}
                                    alt={step.title}
                                    class="w-[85%] object-contain mix-blend-multiply relative z-10"
                                />
                            </div>

                            <div class="hidden sm:flex flex-col items-center relative z-10 pt-1">
                                <div class="absolute inset-0 w-14 h-14 rounded-full bg-slate-200 scale-0 opacity-0 step-sonar" />

                                <div class="w-14 h-14 rounded-full bg-[#FAFAFA] border-2 border-[#E4E4E7] flex items-center justify-center text-[14px] font-bold text-[#A1A1AA] step-node transition-all duration-500 relative z-10">
                                    {step.number}
                                </div>
                            </div>

                            <div class="flex-1 pt-3 pb-12">
                                <h3 class="text-[28px] md:text-[36px] font-semibold tracking-tight text-[#09090B] mb-5">
                                    {step.title}
                                </h3>
                                <p class="text-[17px] md:text-[18px] leading-[1.75] text-[#71717A] font-normal max-w-[480px]">
                                    {step.description}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const steps = document.querySelectorAll(".scroll-step");
        const visuals = document.querySelectorAll('[id^="visual-"]');
        const progressLine = document.getElementById("scroll-progress-line");

        if (steps.length > 0) steps[0].classList.add("is-active");

        // Intersection Observer configuration
        const observerOptions = {
            root: null,
            rootMargin: "-40% 0px -40% 0px", // Triggers dead center of the screen
            threshold: 0,
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const index = parseInt(
                        entry.target.getAttribute("data-index") || "0",
                    );

                    // 1. Smooth Text States
                    steps.forEach((step) => step.classList.remove("is-active"));
                    entry.target.classList.add("is-active");

                    // 2. Crossfade & Scale Visuals
                    visuals.forEach((visual) => {
                        visual.classList.remove(
                            "opacity-100",
                            "scale-100",
                            "translate-y-0",
                        );
                        visual.classList.add(
                            "opacity-0",
                            "scale-90",
                            "translate-y-12",
                        );
                    });

                    const activeVisual = document.getElementById(
                        `visual-${index}`,
                    );
                    if (activeVisual) {
                        activeVisual.classList.remove(
                            "opacity-0",
                            "scale-90",
                            "translate-y-12",
                        );
                        activeVisual.classList.add(
                            "opacity-100",
                            "scale-100",
                            "translate-y-0",
                        );
                    }

                    // 3. Fluid Timeline Progress
                    if (progressLine) {
                        const totalSteps = steps.length - 1;
                        const percentage = (index / totalSteps) * 100;
                        progressLine.style.height = `${percentage}%`;
                    }
                }
            });
        }, observerOptions);

        steps.forEach((step) => observer.observe(step));
    });
</script>
