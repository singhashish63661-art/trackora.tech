---
import { Icon } from "astro-icon/components";

import { getHomeSettings } from "../../lib/home-settings";

const homeSettings = await getHomeSettings();
const services = homeSettings.services;

const dashboardVideoUrl = services.dashboardVideoUrl;
---

<section
    id="command-center"
    class="relative w-full py-20 lg:py-32 bg-[#FAFAFA] dark:bg-[#09090B] font-sans text-[#09090B] dark:text-white overflow-hidden border-t border-[#E4E4E7] dark:border-white/10"
>
    <div
        class="absolute inset-0 z-0 opacity-20 pointer-events-none hidden md:block"
    >
        <div
            class="absolute inset-0 bg-[linear-gradient(to_right,#000000_1px,transparent_1px),linear-gradient(to_bottom,#000000_1px,transparent_1px)] bg-[size:6rem_6rem] [mask-image:radial-gradient(ellipse_80%_80%_at_50%_20%,#000_20%,transparent_100%)] opacity-[0.05]"
        >
        </div>
    </div>

    <div
        class="absolute top-[30%] left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-sky-100/50 rounded-full blur-[120px] pointer-events-none z-0"
    >
    </div>

    <div
        class="relative w-full max-w-[1440px] mx-auto px-6 lg:px-12 z-10 flex flex-col items-center"
    >
        <div
            class="w-full flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-16 lg:mb-24 animate-fade-in-up"
        >
            <div class="max-w-[700px]">
                <div
                    class="flex items-center gap-2 px-3 py-1.5 border border-[#E4E4E7] dark:border-white/10 bg-white dark:bg-[#121214] rounded-full mb-6 shadow-[0_2px_10px_rgba(0,0,0,0.02)] w-max"
                >
                    <span class="relative flex h-1.5 w-1.5 ml-1">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-1.5 w-1.5 bg-blue-500"
                        ></span>
                    </span>
                    <span
                        class="text-[10px] font-bold tracking-[0.1em] uppercase text-[#52525B] dark:text-[#C4C4CE]"
                        >{services.operationalBadgeText}</span
                    >
                </div>

                <h2
                    class="text-[32px] md:text-[48px] lg:text-[56px] font-medium leading-[1.05] tracking-[-0.04em] text-[#09090B] dark:text-white"
                >
                    {services.headingLine1} <br class="hidden sm:block" /> {services.headingLine2}
                </h2>
            </div>

            <div class="max-w-[450px] lg:pb-3">
                <p
                    class="text-[16px] md:text-[17px] leading-[1.65] text-[#71717A] dark:text-[#A1A1AA] font-normal"
                >
                    {services.description}
                </p>
                <a
                    href={services.exploreDashboardHref}
                    onclick="window.trackEvent?.('cta_click', { location: 'services_explore' })"
                    class="inline-flex items-center gap-2 mt-6 text-[13px] font-bold tracking-wide text-[#09090B] dark:text-white hover:text-blue-600 transition-colors group"
                >
                    {services.exploreDashboardText}
                    <Icon
                        name="mdi:arrow-right"
                        class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"
                    />
                </a>
            </div>
        </div>

        <div
            class="relative w-full max-w-[1200px] perspective-1000 mt-4 lg:mt-8 mx-auto"
        >
            <div
                id="dashboard-frame"
                class="relative w-full p-2 lg:p-3 rounded-2xl border border-[#E2E8F0] dark:border-white/10/80 bg-white dark:bg-[#121214]/60 backdrop-blur-2xl shadow-[0_20px_80px_rgba(0,0,0,0.06)] overflow-hidden transform-gpu rotate-x-[12deg] scale-95 opacity-0 transition-all duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)]"
            >
                <div
                    class="w-full h-full rounded-xl overflow-hidden border border-[#E2E8F0] dark:border-white/10 bg-white dark:bg-[#121214] flex flex-col shadow-sm"
                >
                    <div
                        class="flex items-center gap-2 px-4 lg:px-5 py-3 border-b border-[#F1F5F9] bg-[#FAFAFA] dark:bg-[#09090B]"
                    >
                        <div
                            class="flex items-center gap-1.5 lg:gap-2 w-[80px] lg:w-[100px]"
                        >
                            <div class="w-2.5 h-2.5 rounded-full bg-[#E2E8F0]">
                            </div>
                            <div class="w-2.5 h-2.5 rounded-full bg-[#E2E8F0]">
                            </div>
                            <div class="w-2.5 h-2.5 rounded-full bg-[#E2E8F0]">
                            </div>
                        </div>

                        <div class="flex-1 flex justify-center">
                            <div
                                class="w-[200px] lg:w-[240px] h-7 rounded-md bg-[#F1F5F9] border border-[#E2E8F0] dark:border-white/10/50 flex items-center justify-center"
                            >
                                <span
                                    class="text-[10px] text-[#94A3B8] font-medium tracking-wide flex items-center gap-1.5"
                                >
                                    <Icon
                                        name="mdi:lock"
                                        class="w-3 h-3 text-[#CBD5E1]"
                                    /> {services.appLabel}
                                </span>
                            </div>
                        </div>

                        <div class="w-[80px] lg:w-[100px]"></div>
                    </div>

                    <div class="relative w-full aspect-video bg-[#F8FAFC] dark:bg-[#18181A]">
                        {dashboardVideoUrl && (
                            <>
                                <div
                                    class="absolute inset-0 flex items-center justify-center z-0"
                                >
                                    <Icon
                                        name="mdi:loading"
                                        class="w-8 h-8 text-[#CBD5E1] animate-spin"
                                    />
                                </div>
                                <video
                                    autoplay
                                    loop
                                    muted
                                    playsinline
                                    preload="metadata"
                                    class="relative z-10 w-full h-full object-cover"
                                >
                                    <source
                                        src={dashboardVideoUrl}
                                        type="video/mp4"
                                    />
                                </video>
                            </>
                        )}
                    </div>
                </div>
            </div>

            <div
                class="hidden md:block absolute -top-6 -right-2 lg:-top-10 lg:-right-6 z-20 animate-float"
                style="animation-delay: 0s;"
            >
                <div
                    class="flex items-center gap-3.5 p-3.5 rounded-xl bg-white dark:bg-[#121214]/50 backdrop-blur-xl border border-slate-200/80 shadow-[0_12px_32px_rgba(0,0,0,0.06)]"
                >
                    <div
                        class="w-9 h-9 rounded-lg bg-gradient-to-br from-slate-700 via-slate-800 to-[#09090B] flex items-center justify-center shadow-md border border-white dark:border-white/10"
                    >
                        <Icon
                                name={services.routeOptimizedIcon}
                            class="w-5 h-5 text-white dark:text-[#09090B]/90"
                        />
                    </div>
                    <div class="flex flex-col pr-3">
                        <span
                            class="text-[13px] font-bold text-[#09090B] dark:text-white tracking-wide leading-tight mb-0.5"
                            >{services.routeOptimizedTitle}</span
                        >
                        <span class="text-[11px] text-slate-500 font-medium"
                            >{services.routeOptimizedSubtitle}</span
                        >
                    </div>
                </div>
            </div>

            <div
                class="hidden md:block absolute -bottom-8 -left-2 lg:-bottom-12 lg:-left-6 z-20 animate-float-delayed"
                style="animation-delay: 2s;"
            >
                <div
                    class="flex items-center gap-3.5 p-3.5 rounded-xl bg-white dark:bg-[#121214]/50 backdrop-blur-xl border border-slate-200/80 shadow-[0_12px_32px_rgba(0,0,0,0.06)]"
                >
                    <div
                        class="w-9 h-9 rounded-lg bg-gradient-to-br from-slate-700 via-slate-800 to-[#09090B] flex items-center justify-center shadow-md border border-white dark:border-white/10"
                    >
                        <Icon
                            name={services.activeFleetIcon}
                            class="w-5 h-5 text-white dark:text-[#09090B]/90 animate-pulse"
                        />
                    </div>
                    <div class="flex flex-col pr-3">
                        <span
                            class="text-[13px] font-bold text-[#09090B] dark:text-white tracking-wide leading-tight mb-0.5"
                            >{services.activeFleetTitle}</span
                        >
                        <span class="text-[11px] text-slate-500 font-medium"
                            >{services.activeFleetSubtitle}</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // Intersection Observer to trigger the 3D dashboard unfold effect on scroll
    document.addEventListener("DOMContentLoaded", () => {
        const dashboardFrame = document.getElementById("dashboard-frame");

        if (!dashboardFrame) return;

        const observerOptions = {
            root: null,
            rootMargin: "0px 0px -15% 0px",
            threshold: 0.1,
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    // Unfold animation
                    dashboardFrame.classList.add("is-unfolded");
                    observer.unobserve(dashboardFrame);
                }
            });
        }, observerOptions);

        observer.observe(dashboardFrame);
    });
</script>
