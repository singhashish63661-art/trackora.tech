---
import { Icon } from "astro-icon/components";
import { getHomeSettings } from "../../lib/home-settings";

const homeSettings = await getHomeSettings();
const core = homeSettings.coreFeatures;
const features = core.items;
---

<section
    id="features"
    class="relative w-full py-20 lg:py-32 bg-[#FAFAFA] font-sans text-[#09090B] border-t border-[#E4E4E7] overflow-hidden"
>
    <div
        class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-300 to-transparent opacity-50"
    >
    </div>
    <div
        class="absolute top-[-20%] left-[20%] w-[60vw] h-[60vw] bg-slate-200/40 rounded-full blur-[120px] pointer-events-none z-0"
    >
    </div>

    <div class="relative w-full max-w-[1400px] mx-auto px-6 lg:px-12 z-10">
        <div
            class="flex flex-col items-center text-center mb-16 lg:mb-24 animate-fade-in-up"
        >
            <div
                class="flex items-center gap-2 px-4 py-1.5 border border-slate-200/80 bg-white/50 backdrop-blur-md rounded-full mb-6 shadow-sm"
            >
                <span
                    class="text-[11px] font-bold tracking-[0.1em] uppercase text-slate-500"
                    >{core.badgeText}</span
                >
            </div>
            <h2
                class="text-[40px] md:text-[56px] font-medium leading-[1.05] tracking-[-0.03em] text-[#09090B] mb-6 max-w-[800px]"
            >
                {core.title}
            </h2>
            <p
                class="text-[17px] leading-[1.6] text-slate-500 font-normal max-w-[600px]"
            >
                {core.subtitle}
            </p>
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-6"
        >
            {
                features.map((feature, index) => (
                    <div
                        class={`group relative bg-white rounded-[2rem] p-8 lg:p-10 border border-slate-200/80 shadow-[0_4px_24px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] hover:border-slate-300 transition-all duration-500 overflow-hidden flex flex-col ${feature.colSpan} animate-fade-in-up`}
                        style={`animation-delay: ${0.1 + index * 0.1}s;`}
                    >
                        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(241,245,249,0.8)_0%,transparent_60%)] opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none z-0" />

                        <div class="relative z-10 w-14 h-14 rounded-2xl bg-gradient-to-br from-slate-700 via-slate-800 to-[#09090B] flex items-center justify-center mb-16 lg:mb-20 shadow-lg shadow-slate-900/10 transform transition-transform duration-500 group-hover:scale-110 group-hover:-translate-y-1">
                            <div class="absolute inset-0 rounded-2xl border border-white/10" />
                            <Icon
                                name={feature.icon}
                                class="w-7 h-7 text-white/90 drop-shadow-md"
                            />
                        </div>

                        <div class="relative z-10 mt-auto">
                            <h3 class="text-[20px] font-semibold tracking-tight text-[#09090B] mb-3 transition-colors duration-300">
                                {feature.title}
                            </h3>
                            <p class="text-[15px] leading-[1.65] text-slate-500 font-normal">
                                {feature.description}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
