---
import { Icon } from "astro-icon/components";

import { getHomeSettings } from "../../lib/home-settings";

const homeSettings = await getHomeSettings();
const hero = homeSettings.hero;

const videoSource = hero.videoUrl;
const pressLogos = hero.pressLogos ?? [];
---

<section
    class="relative w-full min-h-screen bg-[#FAFAFA] dark:bg-[#09090B] flex flex-col font-sans text-[#09090B] dark:text-white selection:bg-[#E4E4E7] dark:bg-white/10 selection:text-[#09090B] dark:text-white overflow-hidden"
>
    <div
        class="absolute inset-0 z-0 opacity-20 pointer-events-none hidden md:block"
    >
        <div
            class="absolute inset-0 bg-[linear-gradient(to_right,#000000_1px,transparent_1px),linear-gradient(to_bottom,#000000_1px,transparent_1px)] bg-[size:6rem_6rem] [mask-image:radial-gradient(ellipse_80%_80%_at_50%_50%,#000_20%,transparent_100%)] opacity-[0.05]"
        >
        </div>

        <div
            class="absolute top-32 left-16 w-3 h-3 border-t border-l border-black/20"
        >
        </div>
        <div
            class="absolute bottom-32 right-16 w-3 h-3 border-b border-r border-black/20"
        >
        </div>
    </div>

    <main
        class="flex-1 w-full max-w-[1600px] mx-auto flex flex-col lg:grid lg:grid-cols-12 relative z-10"
    >
        <div
            class="lg:col-span-5 relative px-6 pt-10 pb-10 lg:pl-[120px] lg:pr-8 lg:py-12 flex flex-col justify-center"
        >
            <div
                class="hidden lg:flex flex-col items-center absolute bottom-16 left-[40px] animate-fade-in-up"
                style="animation-delay: 0.6s;"
            >
                <span
                    class="text-[9px] font-bold tracking-[0.25em] text-[#71717A] dark:text-[#71717A] uppercase rotate-[-90deg] mb-10 whitespace-nowrap"
                    >Scroll</span
                >
                <div
                    class="w-[1px] h-16 bg-[#E4E4E7] dark:bg-white/10 relative overflow-hidden"
                >
                    <div
                        class="w-full h-1/2 bg-[#09090B] dark:bg-[#121214] absolute top-0 animate-scroll-line"
                    >
                    </div>
                </div>
            </div>

            <div
                class="flex items-center gap-3 mb-8 lg:mb-10 animate-fade-in-up"
                style="animation-delay: 0.1s;"
            >
                <div
                    class="flex items-center gap-2 px-3 py-1.5 border border-[#E4E4E7] dark:border-white/10 bg-white dark:bg-[#121214] rounded-full shadow-[0_2px_10px_rgba(0,0,0,0.02)]"
                >
                    <div
                        class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"
                    >
                    </div>
                    <span
                        class="text-[10px] lg:text-[11px] font-bold tracking-[0.08em] uppercase text-[#52525B] dark:text-[#C4C4CE]"
                        >{hero.badgeText}</span
                    >
                </div>
            </div>

            <h1
                class="text-[32px] sm:text-[38px] md:text-[52px] lg:text-[60px] font-medium leading-[1.05] tracking-[-0.04em] text-[#09090B] dark:text-white mb-5 animate-fade-in-up"
                style="animation-delay: 0.2s;"
            >
                {hero.titleLine1}
                <br />
                {hero.titleLine2}
            </h1>

            <p
                class="text-[15px] lg:text-[16px] leading-[1.65] text-[#71717A] dark:text-[#A1A1AA] font-normal mb-8 max-w-[420px] animate-fade-in-up"
                style="animation-delay: 0.3s;"
            >
                {hero.description}
            </p>

            <div
                class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-4 lg:gap-6 animate-fade-in-up"
                style="animation-delay: 0.4s;"
            >
                <a
                    href="/contact"
                    onclick="window.trackEvent?.('cta_click', { location: 'hero_primary', target: '/contact' })"
                    class="group relative flex items-center justify-center gap-3 bg-[#09090B] dark:bg-[#121214] text-white dark:text-white px-6 py-3.5 lg:px-8 lg:py-4 font-medium text-[12px] lg:text-[13px] tracking-wide rounded-none overflow-hidden hover:shadow-xl transition-all duration-300 w-full sm:w-auto min-h-[48px]"
                >
                    <span class="relative z-10">{hero.ctaText}</span>
                    <Icon
                        name="mdi:arrow-right"
                        class="relative z-10 w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300"
                    />
                    <div
                        class="absolute inset-0 bg-[#27272A] transform scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-500 ease-out"
                    >
                    </div>
                </a>

                <a
                    href={hero.viewDemoHref}
                    onclick="window.trackEvent?.('cta_click', { location: 'hero_secondary' })"
                    class="text-[12px] lg:text-[13px] font-medium text-[#71717A] dark:text-[#A1A1AA] hover:text-[#09090B] dark:text-white transition-colors flex items-center justify-center gap-2 w-full sm:w-auto min-h-[48px]"
                >
                    <div
                        class="w-8 h-8 rounded-full border border-[#E4E4E7] dark:border-white/10 flex items-center justify-center group-hover:border-[#09090B] dark:border-white/10 transition-colors"
                    >
                        <Icon name="mdi:play" class="w-4 h-4" />
                    </div>
                    {hero.viewDemoText}
                </a>
            </div>
        </div>

        <div
            class="lg:col-span-7 relative px-6 lg:px-16 py-8 lg:py-16 flex items-center justify-center pointer-events-none animate-fade-in-up order-first lg:order-last"
            style="animation-delay: 0.3s;"
        >
            <div
                class="relative w-full max-w-[400px] md:max-w-[600px] lg:max-w-[850px] flex items-center justify-center"
            >
                {videoSource && (
                    <video
                        autoplay
                        loop
                        muted
                        playsinline
                        preload="metadata"
                        class="w-full h-auto object-contain mix-blend-multiply contrast-[1.05] brightness-[1.02] [mask-image:radial-gradient(circle_at_center,black_50%,transparent_80%)] -webkit-[mask-image:radial-gradient(circle_at_center,black_50%,transparent_80%)] scale-105 lg:scale-[1.15]"
                    >
                        <source src={videoSource} type="video/mp4" />
                    </video>
                )}
            </div>
        </div>
    </main>

    <footer
        class="w-full px-6 lg:px-16 pb-8 lg:pb-10 z-20 relative flex flex-col md:flex-row justify-between items-start md:items-end gap-8 md:gap-0 animate-fade-in-up"
        style="animation-delay: 0.5s;"
    >
        <div
            class="flex flex-wrap items-center gap-6 lg:gap-8 opacity-60 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500 w-full md:w-auto"
        >
            {pressLogos.length
                ? pressLogos.map((logo) => (
                      <div class="flex items-center gap-1.5 shrink-0 text-[#09090B] dark:text-white cursor-default">
                          {logo.icon && (
                              <Icon
                                  name={logo.icon}
                                  class="w-4 h-4 text-current"
                              />
                          )}
                          <span class={`text-current ${logo.fontStyle}`}>
                              {logo.text}
                          </span>
                      </div>
                  ))
                : null}
        </div>

        <div
            class="flex items-center gap-8 md:border-l border-[#E4E4E7] dark:border-white/10 md:pl-8 w-full md:w-auto justify-between sm:justify-start"
        >
            <div class="flex flex-col">
                <span
                    class="text-[20px] lg:text-[24px] font-semibold tracking-tight text-[#09090B] dark:text-white leading-none"
                    >50M+</span
                >
                <span
                    class="text-[10px] lg:text-[11px] text-[#71717A] dark:text-[#71717A] uppercase tracking-[0.15em] font-medium mt-1.5"
                    >Miles Monitored</span
                >
            </div>
            <div class="flex flex-col">
                <span
                    class="text-[20px] lg:text-[24px] font-semibold tracking-tight text-[#09090B] dark:text-white leading-none"
                    >99.9%</span
                >
                <span
                    class="text-[10px] lg:text-[11px] text-[#71717A] dark:text-[#71717A] uppercase tracking-[0.15em] font-medium mt-1.5"
                    >System Uptime</span
                >
            </div>
        </div>
    </footer>
</section>
