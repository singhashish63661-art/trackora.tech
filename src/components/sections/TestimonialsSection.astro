---
import { Icon } from "astro-icon/components";
import { getHomeSettings } from "../../lib/home-settings";
const homeSettings = await getHomeSettings();
const testimonialsSettings = homeSettings.testimonials;
const testimonials = testimonialsSettings.items;
const caseStudies = testimonialsSettings.caseStudies ?? [];
---

<section
    id="testimonials"
    class="relative w-full py-20 lg:py-32 bg-[#FAFAFA] dark:bg-[#09090B] font-sans text-[#09090B] dark:text-white border-t border-[#E4E4E7] dark:border-white/10 overflow-hidden"
>
    <div
        class="absolute inset-0 z-0 opacity-20 pointer-events-none hidden md:block"
    >
        <div
            class="absolute inset-0 bg-[linear-gradient(to_right,#000000_1px,transparent_1px),linear-gradient(to_bottom,#000000_1px,transparent_1px)] bg-[size:6rem_6rem] [mask-image:radial-gradient(ellipse_80%_80%_at_50%_50%,#000_20%,transparent_100%)] opacity-[0.05]"
        >
        </div>
    </div>

    <div class="relative w-full max-w-[1440px] mx-auto px-6 lg:px-12 z-10">
        <div
            class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center relative"
        >
            <div
                class="lg:col-span-5 flex flex-col items-start animate-fade-in-up z-20"
            >
                <div
                    class="flex items-center gap-2.5 px-3 py-1.5 border border-[#E4E4E7] dark:border-white/10 bg-white dark:bg-[#121214] rounded-full mb-8 shadow-sm"
                >
                    <span
                        class="text-[10px] font-bold tracking-[0.15em] uppercase text-[#52525B] dark:text-[#C4C4CE]"
                        >{testimonialsSettings.badgeText}</span
                    >
                </div>

                <h2
                    class="text-[32px] md:text-[48px] lg:text-[56px] font-medium leading-[1.05] tracking-[-0.04em] text-[#09090B] dark:text-white mb-6 lg:mb-8"
                >
                    {testimonialsSettings.title}
                </h2>

                <p
                    class="text-[16px] md:text-[17px] leading-[1.65] text-[#71717A] dark:text-[#A1A1AA] font-normal max-w-[440px] mb-10 lg:mb-12"
                >
                    {testimonialsSettings.subtitle}
                </p>

                <div class="flex gap-4">
                    <button
                        id="slider-prev"
                        aria-label="Previous testimonial"
                        class="w-12 h-12 rounded-full border border-[#E4E4E7] dark:border-white/10 bg-white dark:bg-[#121214] flex items-center justify-center hover:bg-[#09090B] dark:bg-[#121214] hover:text-white dark:text-[#09090B] hover:border-[#09090B] dark:border-white/10 transition-all duration-300 shadow-sm disabled:opacity-30 disabled:hover:bg-white dark:bg-[#121214] disabled:hover:text-[#09090B] dark:text-white disabled:hover:border-[#E4E4E7] dark:border-white/10 disabled:cursor-not-allowed"
                    >
                        <Icon name="mdi:arrow-left" class="w-5 h-5" />
                    </button>
                    <button
                        id="slider-next"
                        aria-label="Next testimonial"
                        class="w-12 h-12 rounded-full border border-[#E4E4E7] dark:border-white/10 bg-white dark:bg-[#121214] flex items-center justify-center hover:bg-[#09090B] dark:bg-[#121214] hover:text-white dark:text-[#09090B] hover:border-[#09090B] dark:border-white/10 transition-all duration-300 shadow-sm disabled:opacity-30 disabled:hover:bg-white dark:bg-[#121214] disabled:hover:text-[#09090B] dark:text-white disabled:hover:border-[#E4E4E7] dark:border-white/10 disabled:cursor-not-allowed"
                    >
                        <Icon name="mdi:arrow-right" class="w-5 h-5" />
                    </button>
                </div>
            </div>

            <div
                class="lg:col-span-7 relative w-full animate-fade-in-up"
                style="animation-delay: 0.2s;"
            >
                <div
                    class="absolute top-0 right-0 bottom-0 w-16 lg:w-32 bg-gradient-to-l from-[#FAFAFA] to-transparent z-20 pointer-events-none"
                >
                </div>

                <div
                    class="w-full overflow-hidden relative py-8"
                    id="slider-viewport"
                >
                    <div
                        id="slider-track"
                        class="flex flex-row gap-6 w-max"
                        style="transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);"
                    >
                        {
                            testimonials.map((item, index) => (
                                <div class="slider-card w-[85vw] sm:w-[360px] lg:w-[420px] shrink-0 bg-white dark:bg-[#121214] border border-[#E4E4E7] dark:border-white/10 rounded-3xl p-8 lg:p-10 shadow-[0_2px_10px_rgba(0,0,0,0.02)] hover:border-[#09090B] dark:border-white/10 transition-colors duration-500 flex flex-col justify-between cursor-grab active:cursor-grabbing">
                                    <div>
                                        <div class="flex items-start justify-between mb-8">
                                            <div class="flex flex-col">
                                                <div class="flex gap-1 mb-3 lg:mb-4">
                                                    {[
                                                        ...Array(item.rating),
                                                    ].map(() => (
                                                        <Icon
                                                            name="mdi:star"
                                                            class="w-3.5 h-3.5 text-[#09090B] dark:text-white"
                                                        />
                                                    ))}
                                                </div>
                                                <span class="text-[16px] lg:text-[18px] font-bold tracking-tight text-[#09090B] dark:text-white leading-none mb-1.5">
                                                    {item.name}
                                                </span>
                                                <span class="text-[11px] lg:text-[12px] text-[#71717A] dark:text-[#A1A1AA] font-medium uppercase tracking-wider">
                                                    {item.role}
                                                </span>
                                            </div>

                                            {index === 0 ? (
                                                <div class="w-10 h-10 rounded-xl bg-[#09090B] flex items-center justify-center shadow-md border border-white/10 pointer-events-none">
                                                    <Icon
                                                        name="mdi:shield-check"
                                                        class="w-5 h-5 text-white"
                                                    />
                                                </div>
                                            ) : (
                                                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-slate-700 via-slate-800 to-[#09090B] flex items-center justify-center shadow-md border border-white dark:border-white/10 pointer-events-none">
                                                    <Icon
                                                        name="mdi:check-decagram"
                                                        class="w-5 h-5 text-white dark:text-[#09090B]/90"
                                                    />
                                                </div>
                                            )}
                                        </div>

                                        <p class="text-[15px] lg:text-[17px] leading-[1.65] text-[#3F3F46] dark:text-[#D4D4D8] font-normal italic pointer-events-none">
                                            “{item.quote}”
                                        </p>
                                    </div>

                                    <div class="mt-8 flex items-center justify-between text-[9px] lg:text-[10px] font-bold tracking-[0.15em] text-[#A1A1AA] dark:text-[#71717A] uppercase border-t border-[#F1F5F9] pt-6 pointer-events-none">
                                        <span>Verified Partnership</span>
                                        <span>2 Months Ago</span>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
        {caseStudies.length > 0 && (
            <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-4">
                {caseStudies.map((item) => (
                    <div class="rounded-2xl border border-[#E4E4E7] bg-white p-6">
                        <p class="text-xs uppercase tracking-[0.16em] text-[#71717A] mb-2">Case Study</p>
                        <p class="text-lg font-semibold text-[#09090B] mb-1">{item.title}</p>
                        <p class="text-sm text-[#71717A]"><span class="font-semibold text-[#09090B]">{item.metric}</span> {item.detail}</p>
                    </div>
                ))}
            </div>
        )}
    </div>
</section>

<style>
    :root {
        font-family:
            "Plus Jakarta Sans",
            system-ui,
            -apple-system,
            sans-serif;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }
</style>

<script>
    function initPremiumSlider() {
        const track = document.getElementById("slider-track");
        const viewport = document.getElementById("slider-viewport");
        const prevBtn = document.getElementById(
            "slider-prev",
        ) as HTMLButtonElement;
        const nextBtn = document.getElementById(
            "slider-next",
        ) as HTMLButtonElement;
        const cards = document.querySelectorAll(".slider-card");

        if (!track || !viewport || !prevBtn || !nextBtn || cards.length === 0)
            return;

        let currentIndex = 0;

        // Calculate the exact slide distance (Card Width + Gap)
        const updateSlider = () => {
            const card = cards[0] as HTMLElement;
            const gap = 24; // Matches the gap-6 class (24px)
            const slideDistance = card.offsetWidth + gap;

            // Calculate maximum slides based on viewport width to prevent scrolling into empty space
            const viewportWidth = viewport.offsetWidth;
            const trackWidth = track.scrollWidth;
            const maxScroll = trackWidth - viewportWidth;

            let targetTranslate = currentIndex * slideDistance;

            // Prevent over-scrolling at the end
            if (targetTranslate > maxScroll) {
                targetTranslate = maxScroll;
                // Force button states
                nextBtn.disabled = true;
            } else {
                nextBtn.disabled = false;
            }

            // Prevent over-scrolling at the beginning
            if (targetTranslate <= 0) {
                targetTranslate = 0;
                currentIndex = 0;
                prevBtn.disabled = true;
            } else {
                prevBtn.disabled = false;
            }

            // Apply the hardware-accelerated transform
            track.style.transform = `translate3d(-${targetTranslate}px, 0, 0)`;
        };

        // Event Listeners
        nextBtn.addEventListener("click", () => {
            currentIndex++;
            updateSlider();
        });

        prevBtn.addEventListener("click", () => {
            currentIndex--;
            updateSlider();
        });

        // Handle Window Resize to recalculate widths
        window.addEventListener("resize", () => {
            updateSlider();
        });

        // Initialize button states
        updateSlider();
    }

    // Initialize on direct load
    initPremiumSlider();

    // Support for Astro View Transitions (if enabled)
    document.addEventListener("astro:page-load", initPremiumSlider);
</script>
