---
import { Icon } from "astro-icon/components";

interface Props {
    badgeText?: string;
    title: string;
    description: string;
    primaryBtnText?: string;
    primaryBtnHref?: string;
    secondaryBtnText?: string;
    secondaryBtnHref?: string;
    trustHighlight?: string;
    trustText?: string;
    illustrationUrl: string;
}

const {
    badgeText = "Accelerate Today",
    title,
    description,
    primaryBtnText = "Schedule Demo",
    primaryBtnHref = "/contact",
    secondaryBtnText = "Speak with Engineering",
    secondaryBtnHref = "/contact",
    trustHighlight = "400+",
    trustText = "active logistics nodes.",
    illustrationUrl,
} = Astro.props;
---

<section
    id="cta"
    class="relative w-full py-14 sm:py-16 lg:py-32 bg-[#FAFAFA] font-sans text-[#09090B] overflow-hidden"
>
    <!-- Keep background styles unchanged from original (just lines omitted here) -->
    <div class="relative w-full max-w-[1440px] mx-auto px-6 lg:px-12 z-10">
        <div
            class="relative w-full bg-gradient-to-br from-[#18181B] via-[#09090B] to-[#000000] rounded-[2rem] sm:rounded-[2.5rem] lg:rounded-[4rem] overflow-hidden shadow-[0_40px_100px_rgba(0,0,0,0.2)] border border-white/5"
        >
            <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
                <div
                    class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff_1px,transparent_1px),linear-gradient(to_bottom,#ffffff_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_20%,transparent_100%)] opacity-[0.05]"
                >
                </div>
            </div>

            <div
                class="absolute -top-1/4 -right-1/4 w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[120px] pointer-events-none"
            >
            </div>
            <div
                class="absolute -bottom-1/4 -left-1/4 w-[600px] h-[600px] bg-sky-500/10 rounded-full blur-[120px] pointer-events-none"
            >
            </div>

            <div
                class="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-center p-6 sm:p-8 lg:p-24"
            >
                <div
                    class="lg:col-span-7 flex flex-col items-start animate-fade-in-up"
                >
                    <div
                        class="flex items-center gap-2.5 px-4 py-2 border border-white/10 bg-white/5 backdrop-blur-md rounded-full mb-8 shadow-sm"
                    >
                        <span class="relative flex h-2 w-2">
                            <span
                                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"
                            ></span>
                            <span
                                class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"
                            ></span>
                        </span>
                        <span
                            class="text-[10px] font-bold tracking-[0.2em] uppercase text-blue-100/80"
                            >{badgeText}</span
                        >
                    </div>

                    <h2
                        class="text-[30px] sm:text-[40px] md:text-[56px] lg:text-[80px] font-medium leading-[1.05] tracking-[-0.04em] text-white mb-6"
                        set:html={title}
                    />

                    <p
                        class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.6] text-slate-300 font-normal max-w-[500px] mb-8 sm:mb-10"
                    >
                        {description}
                    </p>

                    <div
                        class="flex flex-col sm:flex-row items-center gap-5 w-full sm:w-auto"
                    >
                        <a
                            href={primaryBtnHref}
                            onclick={`window.trackEvent?.('cta_click', { location: 'final_cta', href: '${primaryBtnHref}' }); if ('${primaryBtnHref}' === '/contact') { if (window.openDemoWithFallback) { window.openDemoWithFallback(); } else { window.location.href='/contact'; } return false; }`}
                            class="w-full sm:w-auto px-8 sm:px-10 py-4 sm:py-5 min-h-[48px] bg-white text-[#09090B] text-[14px] font-bold tracking-wide rounded-full shadow-[0_0_30px_rgba(255,255,255,0.1)] hover:shadow-[0_0_50px_rgba(255,255,255,0.2)] hover:scale-[1.02] transition-all duration-300 flex items-center justify-center gap-3 active:scale-95"
                        >
                            {primaryBtnText}
                            <Icon name="mdi:arrow-right" class="w-5 h-5" />
                        </a>

                        {
                            secondaryBtnText && (
                                <a
                                    href={secondaryBtnHref}
                                    class="w-full sm:w-auto px-8 sm:px-10 py-4 sm:py-5 min-h-[48px] bg-transparent border border-white/10 text-white text-[14px] font-bold tracking-wide rounded-full hover:bg-white/5 transition-all duration-300 flex items-center justify-center gap-3"
                                >
                                    {secondaryBtnText}
                                </a>
                            )
                        }
                    </div>

                    <div class="mt-8 sm:mt-10 flex items-center gap-4 text-slate-300 flex-wrap">
                        <div class="flex -space-x-2">
                            {
                                [1, 2, 3].map(() => (
                                    <div class="w-7 h-7 rounded-full border-2 border-[#09090B] bg-slate-800" />
                                ))
                            }
                        </div>
                        <span class="text-[12px] font-medium tracking-wide">
                            Infrastructure deployed for <span class="text-white"
                                >{trustHighlight}</span
                            >
                            {trustText}
                        </span>
                    </div>
                </div>

                <div
                    class="lg:col-span-5 relative hidden lg:flex items-center justify-center animate-fade-in-up"
                    style="animation-delay: 0.2s;"
                >
                    <div
                        class="absolute w-[400px] h-[400px] border border-white/5 rounded-full animate-spin-slow"
                    >
                    </div>
                    <div
                        class="absolute w-[300px] h-[300px] border border-white/10 rounded-full animate-spin-reverse-slow"
                    >
                    </div>

                    <div class="relative z-10 p-4">
                        <img
                            src={illustrationUrl}
                            alt="Intelligence Visual"
                            class="w-full max-w-[380px] h-auto object-contain filter drop-shadow-[0_20px_60px_rgba(56,189,248,0.2)]"
                        />
                    </div>

                    <div
                        class="absolute -right-12 top-1/2 -translate-y-1/2 flex flex-col items-center gap-10 text-[9px] font-bold tracking-[0.25em] text-white/20 uppercase rotate-90 whitespace-nowrap"
                    >
                        <span>Precision Scale</span>
                        <div class="w-20 h-px bg-white/10"></div>
                        <span>Status: Optimal</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
